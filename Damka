  function parsePuzzleBoard(rows) {
    const b = Array.from({length:8},()=>Array(8).fill(0));
    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) {
      const ch = rows[r][c];
      if (ch === 'w') b[r][c] = W_MAN;
      else if (ch === 'W') b[r][c] = W_KING;
      else if (ch === 'b') b[r][c] = B_MAN;
      else if (ch === 'B') b[r][c] = B_KING;
    }
    return b;
  }
  function todayDateStr() {
    const d = new Date();
    return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
  }
  function todayPuzzle() {
    const today = new Date();
    const start = new Date(today.getFullYear(), 0, 0);
    const day = Math.floor((today - start) / 86400000);
    return PUZZLES[day % PUZZLES.length];
  }
  function isPuzzleSolvedToday() {
    const date = todayDateStr();
    return (state.profile.puzzleProgress.solved || []).includes(date);
  }
  function recordPuzzleSolved() {
    const p = state.profile;
    const today = todayDateStr();
    if (p.puzzleProgress.solved.includes(today)) return false;
    p.puzzleProgress.solved.push(today);
    const yesterday = new Date(); yesterday.setDate(yesterday.getDate() - 1);
    const ystr = yesterday.getFullYear() + '-' + String(yesterday.getMonth()+1).padStart(2,'0') + '-' + String(yesterday.getDate()).padStart(2,'0');
    p.puzzleProgress.streak = (p.puzzleProgress.lastSolvedDate === ystr) ? p.puzzleProgress.streak + 1 : 1;
    p.puzzleProgress.bestStreak = Math.max(p.puzzleProgress.bestStreak || 0, p.puzzleProgress.streak);
    p.puzzleProgress.lastSolvedDate = today;
    p.boxes.silver = (p.boxes.silver || 0) + 1;
    saveProfile();
    return true;
  }

