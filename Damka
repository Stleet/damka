    if (ix >= 0) lb[ix] = entry; else lb.push(entry);
    Storage.set('lb', lb);
  }

  // ============ Game logic ============
  function newBoard() {
    const b = Array.from({length: 8}, () => Array(8).fill(0));
    for (let r = 0; r < 3; r++) {
      for (let c = 0; c < 8; c++) {
        if ((r + c) % 2 === 1) b[r][c] = B_MAN;
      }
    }
    for (let r = 5; r < 8; r++) {
      for (let c = 0; c < 8; c++) {
        if ((r + c) % 2 === 1) b[r][c] = W_MAN;
      }
    }
    return b;
  }

  function cloneBoard(b) { return b.map(row => row.slice()); }
  function inBounds(r, c) { return r >= 0 && r < 8 && c >= 0 && c < 8; }
  function sgn(x) { return x > 0 ? 1 : x < 0 ? -1 : 0; }

  function pieceAt(board, r, c) { return board[r][c]; }
  function isKing(p) { return Math.abs(p) === 2; }
  function isMan(p) { return Math.abs(p) === 1; }

  // Generate capture sequences starting from (fr,fc). Russian rules:
  // - Man can capture forward AND backward
  // - King is flying: scans any distance along diagonal, jumps single enemy, lands on any empty square beyond
  // - Multi-jump mandatory: must continue capturing if possible
  // - Captured pieces stay on board until end of sequence (block paths, cannot be re-captured)
  // - Promotion only at end of move sequence
  function generateCapturesFrom(board, fr, fc) {
    const piece = board[fr][fc];
    if (piece === 0) return [];
    const side = sgn(piece);
    const startKing = isKing(piece);
    const sequences = [];
    const stepPath = [[fr, fc]];
    const capPath = [];

    function isCapturedAt(r, c) {
      for (const p of capPath) if (p[0] === r && p[1] === c) return true;
      return false;
    }
    function pathEmpty(r, c) {
      if (r === fr && c === fc) return true; // piece left origin
      return board[r][c] === 0;
    }

    // dfs carries currentlyKing flag — man can promote mid-sequence (Russian rule)
    function dfs(r, c, currentlyKing) {
      let extended = false;
      for (const [dr, dc] of DIRS) {
        if (currentlyKing) {
          let nr = r + dr, nc = c + dc;
          while (inBounds(nr, nc) && pathEmpty(nr, nc)) { nr += dr; nc += dc; }
          if (!inBounds(nr, nc)) continue;
          if (isCapturedAt(nr, nc)) continue;
          if (sgn(board[nr][nc]) !== -side) continue;
          const er = nr, ec = nc;
          nr += dr; nc += dc;
          while (inBounds(nr, nc) && pathEmpty(nr, nc)) {
            stepPath.push([nr, nc]);
            capPath.push([er, ec]);
            extended = true;
            dfs(nr, nc, true);
            stepPath.pop();
            capPath.pop();
            nr += dr; nc += dc;
          }
        } else {
          const er = r + dr, ec = c + dc;
          const lr = r + 2*dr, lc = c + 2*dc;
          if (!inBounds(lr, lc)) continue;
          if (isCapturedAt(er, ec)) continue;
          if (board[er][ec] === 0 || sgn(board[er][ec]) !== -side) continue;
          if (!pathEmpty(lr, lc)) continue;
          stepPath.push([lr, lc]);
          capPath.push([er, ec]);
          extended = true;
          const becameKing = (side === WHITE && lr === 0) || (side === BLACK && lr === 7);
          dfs(lr, lc, becameKing);
          stepPath.pop();
          capPath.pop();
        }
      }
      if (!extended && capPath.length > 0) {
        sequences.push({
          steps: stepPath.map(s => [s[0], s[1]]),
          captures: capPath.map(s => [s[0], s[1]]),
          piece,
        });
      }
    }

    dfs(fr, fc, startKing);
    return sequences;
  }

  function generateNonCapturesFrom(board, fr, fc) {
    const piece = board[fr][fc];
    if (piece === 0) return [];
    const king = isKing(piece);
    const side = sgn(piece);
    const moves = [];
    if (king) {
      for (const [dr, dc] of DIRS) {
        let nr = fr + dr, nc = fc + dc;
        while (inBounds(nr, nc) && board[nr][nc] === 0) {
          moves.push({ steps: [[fr,fc],[nr,nc]], captures: [], piece });
          nr += dr; nc += dc;
        }
      }
    } else {
      const fwd = -side;
      for (const dc of [-1, 1]) {
        const nr = fr + fwd, nc = fc + dc;
        if (inBounds(nr, nc) && board[nr][nc] === 0) {
          moves.push({ steps: [[fr,fc],[nr,nc]], captures: [], piece });
        }
      }
    }
    return moves;
  }

  function legalMoves(board, side) {
    const captures = [];
    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) {
      if (sgn(board[r][c]) === side) {
        const seqs = generateCapturesFrom(board, r, c);
        if (seqs.length) captures.push(...seqs);
      }
    }
    if (captures.length) return captures;
    const moves = [];
    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) {
      if (sgn(board[r][c]) === side) {
        const ms = generateNonCapturesFrom(board, r, c);
        if (ms.length) moves.push(...ms);
      }
    }
    return moves;
  }

  function applyMove(board, move) {
    const b = cloneBoard(board);
    const [fr, fc] = move.steps[0];
    const [tr, tc] = move.steps[move.steps.length - 1];
    let piece = b[fr][fc];
    b[fr][fc] = 0;
    for (const [cr, cc] of move.captures) b[cr][cc] = 0;
    // Promotion: any time the man's path touches the back rank
    if (isMan(piece)) {
      for (let i = 1; i < move.steps.length; i++) {
        const sr = move.steps[i][0];
        if ((piece > 0 && sr === 0) || (piece < 0 && sr === 7)) {
          piece = piece > 0 ? W_KING : B_KING;
          break;
        }
      }
    }
    b[tr][tc] = piece;
    return b;
  }

  function countPieces(board, side) {
    let c = 0;
    for (let r = 0; r < 8; r++) for (let cc = 0; cc < 8; cc++)
      if (sgn(board[r][cc]) === side) c++;
    return c;
  }

  function checkGameStatus(board, sideToMove) {
    // sideToMove is who is about to move.
    // White loses if has no pieces or no legal moves; same for black.
    const wPieces = countPieces(board, WHITE);
    const bPieces = countPieces(board, BLACK);
    if (wPieces === 0) return 'won-black';
    if (bPieces === 0) return 'won-white';
    const moves = legalMoves(board, sideToMove);
    if (moves.length === 0) return sideToMove === WHITE ? 'won-black' : 'won-white';
    return 'playing';
  }

  // ============ Notation ============
  // PDN-like: a1..h8. White at the bottom (row 7 -> rank 1).
  function sqName(r, c) {
    const file = 'abcdefgh'[c];
    const rank = 8 - r;
    return file + rank;
  }
  function moveToNotation(move) {
    const sep = move.captures.length ? ':' : '-';
    const from = sqName(move.steps[0][0], move.steps[0][1]);
    const to = sqName(move.steps[move.steps.length-1][0], move.steps[move.steps.length-1][1]);
    if (move.captures.length === 0) return from + sep + to;
    const path = move.steps.slice(1).map(s => sqName(s[0], s[1])).join(':');
    return from + ':' + path;
  }

  // ============ AI ============
  function evaluate(board) {
    let score = 0;
    for (let r = 0; r < 8; r++) {
      for (let c = 0; c < 8; c++) {
        const p = board[r][c];
        if (!p) continue;
        const s = sgn(p);
        let v = isKing(p) ? 320 : 100;
        if (isMan(p)) {
          // Advancement bonus
          v += (s === WHITE ? (7 - r) : r) * 6;
          // Back-rank holding bonus
          if ((s === WHITE && r === 7) || (s === BLACK && r === 0)) v += 12;
          // Wall column bonus (less exposed on a/h files)
          if (c === 0 || c === 7) v += 4;
        }
        // Center bonus
        if (c >= 2 && c <= 5 && r >= 2 && r <= 5) v += 4;
        score += s * v;
      }
    }
    return score;
  }

  // ----- Zobrist hashing for transposition table -----
  // Use BigInt to keep the hash deterministic. 5 piece codes × 64 squares.
  const Z_RNG = (() => {
    let s = 1234567n;
    return () => {
      s = (s * 6364136223846793005n + 1442695040888963407n) & 0xFFFFFFFFFFFFFFFFn;
      return s;
    };
  })();
  const Z_PIECE = (() => {
    // index by (piece+2) and (r*8+c)
    const arr = [];
    for (let p = 0; p < 5; p++) {
      const row = [];
      for (let i = 0; i < 64; i++) row.push(Z_RNG());
      arr.push(row);
    }
    return arr;
  })();
  const Z_SIDE = Z_RNG();
  function zobristHash(board, side) {
    let h = 0n;
    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) {
      const p = board[r][c];
      if (p !== 0) h ^= Z_PIECE[p + 2][r * 8 + c];
    }
    if (side === BLACK) h ^= Z_SIDE;
    return h;
  }

  // Cache: hash -> { depth, score, flag, bestMoveKey }
  // flag: 0 exact, 1 lower bound (alpha), 2 upper bound (beta)
  let TT = new Map();
  const TT_MAX = 200000;
  function ttPut(h, depth, score, flag, bestKey) {
    if (TT.size > TT_MAX) TT.clear();
    TT.set(h.toString(), { depth, score, flag, bestKey });
  }
  function ttGet(h) { return TT.get(h.toString()); }
  function moveKey(m) {
    return m.steps[0][0] + ',' + m.steps[0][1] + '>' +
           m.steps[m.steps.length-1][0] + ',' + m.steps[m.steps.length-1][1];
  }

  function orderMoves(moves, preferredKey) {
    return moves.slice().sort((a, b) => {
      if (preferredKey) {
        if (moveKey(a) === preferredKey) return -1;
        if (moveKey(b) === preferredKey) return 1;
      }
      return b.captures.length - a.captures.length;
    });
  }

  function minimax(board, depth, alpha, beta, side, deadline) {
    if (deadline && performance.now() > deadline) return { score: evaluate(board), move: null, timeout: true };
    const origAlpha = alpha;
    const h = zobristHash(board, side);
    const hit = ttGet(h);
    let ttBestKey = null;
    if (hit && hit.depth >= depth) {
      if (hit.flag === 0) return { score: hit.score, move: null, fromTT: true };
      if (hit.flag === 1 && hit.score >= beta) return { score: hit.score, move: null, fromTT: true };
      if (hit.flag === 2 && hit.score <= alpha) return { score: hit.score, move: null, fromTT: true };
    }
    if (hit) ttBestKey = hit.bestKey;

    const moves = legalMoves(board, side);
    if (moves.length === 0) {
      return { score: side === WHITE ? -100000 + (8 - depth) : 100000 - (8 - depth), move: null };
    }
    if (depth === 0) return { score: evaluate(board), move: null };
    const ordered = orderMoves(moves, ttBestKey);
    let bestMove = ordered[0];
    let bestScore;
    if (side === WHITE) {
      bestScore = -Infinity;
      for (const m of ordered) {
        const next = applyMove(board, m);
        const res = minimax(next, depth - 1, alpha, beta, BLACK, deadline);
        if (res.score > bestScore) { bestScore = res.score; bestMove = m; }
        alpha = Math.max(alpha, bestScore);
        if (beta <= alpha) break;
      }
    } else {
      bestScore = Infinity;
      for (const m of ordered) {
        const next = applyMove(board, m);
        const res = minimax(next, depth - 1, alpha, beta, WHITE, deadline);
        if (res.score < bestScore) { bestScore = res.score; bestMove = m; }
        beta = Math.min(beta, bestScore);
        if (beta <= alpha) break;
      }
    }
    // Store
    let flag = 0;
    if (side === WHITE) {
      if (bestScore <= origAlpha) flag = 2;
      else if (bestScore >= beta) flag = 1;
    } else {
      if (bestScore >= beta) flag = 1;
      else if (bestScore <= origAlpha) flag = 2;
    }
    ttPut(h, depth, bestScore, flag, bestMove ? moveKey(bestMove) : null);
    return { score: bestScore, move: bestMove };
  }

  // Iterative deepening: search depth 1, 2, ... up to target or until time runs out
  function iterativeDeepening(board, side, maxDepth, deadline) {
    let best = null;
    for (let d = 1; d <= maxDepth; d++) {
      const r = minimax(board, d, -Infinity, Infinity, side, deadline);
      if (deadline && performance.now() > deadline) {
        if (best) return best;
        return r;
      }
      if (r.move) best = r;
    }
    return best;
  }

  function pickAIMove(board, side, level) {
    const cfg = AI_LEVELS.find(l => l.id === level) || AI_LEVELS[2];
    const moves = legalMoves(board, side);
    if (moves.length === 0) return null;
    // For easiest: pick semi-randomly to keep things winnable
    if (Math.random() < cfg.rand) {
      return moves[Math.floor(Math.random() * moves.length)];
    }
    const deadline = performance.now() + 1800; // 1.8s time cap
    TT.clear(); // clear between turns; entries from older positions are stale anyway
    const res = iterativeDeepening(board, side, cfg.depth, deadline);
    return (res && res.move) || moves[0];
  }

  // ============ AI Coach analysis ============
  function analyzeHistory(history, playerSide) {
    // history: array of {board (before), move, side}
    const annotations = [];
    let blunders = 0, mistakes = 0, inaccuracies = 0, best = 0;
    let cumLossCp = 0, playerMoves = 0;

    for (let i = 0; i < history.length; i++) {
      const h = history[i];
      // Engine's best for this position
      const res = minimax(h.board, 4, -Infinity, Infinity, h.side, performance.now() + 220);
      // Score from h.side's perspective: positive = good for h.side
      const bestForSide = (h.side === WHITE ? res.score : -res.score);
      const afterActual = applyMove(h.board, h.move);
      // Now opponent to move; evaluate position from opponent perspective, flip sign
      const actualRes = minimax(afterActual, 3, -Infinity, Infinity, -h.side, performance.now() + 150);
      const actualForSide = (h.side === WHITE ? actualRes.score : -actualRes.score);
      const delta = bestForSide - actualForSide; // how much worse than best
      let label;
      if (delta <= 15) label = 'best';
      else if (delta <= 60) label = 'good';
      else if (delta <= 150) label = 'inaccurate';
      else if (delta <= 350) label = 'mistake';
      else label = 'blunder';

      const a = {
        index: i,
        move: h.move,
        side: h.side,
        bestMove: res.move,
        bestScore: bestForSide,
        actualScore: actualForSide,
        delta,
        label,
        notation: moveToNotation(h.move),
        bestNotation: res.move ? moveToNotation(res.move) : '',
        comment: '',
      };
      annotations.push(a);

      if (h.side === playerSide) {
        playerMoves++;
        if (label === 'best') best++;
        else if (label === 'inaccurate') inaccuracies++;
        else if (label === 'mistake') mistakes++;
        else if (label === 'blunder') blunders++;
        cumLossCp += Math.max(0, delta);
      }
    }

    // Add commentary
    for (const a of annotations) {
      if (a.label === 'best') {
        a.comment = 'Лучший ход в позиции. Хорошо!';
      } else if (a.label === 'good') {
        a.comment = 'Хороший ход — близко к оптимуму.';
      } else if (a.label === 'inaccurate') {
        a.comment = `Неточность. Сильнее было ${a.bestNotation}.`;
      } else if (a.label === 'mistake') {
        a.comment = `Ошибка: вы упустили преимущество. Лучшим был ${a.bestNotation}.`;
        if (a.bestMove && a.bestMove.captures.length > a.move.captures.length)
          a.comment += ' Здесь было взятие.';
      } else if (a.label === 'blunder') {
        a.comment = `Грубая ошибка! Этот ход проигрывает позицию. Сильнее ${a.bestNotation}.`;
        if (a.bestMove && a.bestMove.captures.length > a.move.captures.length)
          a.comment += ` Была возможность взятия ${a.bestMove.captures.length} шашки.`;
      }
    }

    const accuracy = playerMoves === 0 ? 100 : Math.max(0, Math.min(100, 100 - cumLossCp / playerMoves / 4));

    return {
      annotations,
      summary: {
        best, inaccuracies, mistakes, blunders,
        playerMoves,
        accuracy: Math.round(accuracy),
      },
    };
  }

  // ============ Sound (simple Web Audio synth) ============
  let audioCtx = null;
  function getAudio() {
    if (!state.profile?.sound) return null;
    if (!audioCtx) {
      try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
      catch { return null; }
    }
    return audioCtx;
  }
  function blip(freq, dur, type = 'sine', vol = 0.06) {
    const ctx = getAudio(); if (!ctx) return;
    const o = ctx.createOscillator();
    const g = ctx.createGain();
    o.type = type; o.frequency.value = freq;
    g.gain.value = 0;
    g.gain.linearRampToValueAtTime(vol, ctx.currentTime + 0.005);
    g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + dur);
    o.connect(g).connect(ctx.destination);
    o.start();
    o.stop(ctx.currentTime + dur);
  }
  const Sound = {
    select: () => blip(620, 0.05, 'square', 0.04),
    move:   () => blip(440, 0.12, 'sine', 0.05),
    capture:() => { blip(360, 0.06, 'square', 0.06); setTimeout(()=>blip(280,0.10,'square',0.06),60); },
    king:   () => { blip(800,0.10,'triangle',0.07); setTimeout(()=>blip(1200,0.14,'triangle',0.07),80); },
    win:    () => { blip(660,0.12,'triangle',0.08); setTimeout(()=>blip(880,0.14,'triangle',0.08),120); setTimeout(()=>blip(1175,0.20,'triangle',0.08),260); },
    lose:   () => { blip(330,0.16,'sine',0.06); setTimeout(()=>blip(220,0.30,'sine',0.06),140); },
    tick:   () => blip(900,0.02,'square',0.025),
  };

