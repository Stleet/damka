    const mp = { peer, conn: null, role: 'guest', roomId };
    state.multiplayer = mp;
    peer.on('open', () => {
      const conn = peer.connect(roomId, { reliable: true });
      mp.conn = conn;
      conn.on('open', () => {
        conn.on('data', (d) => onMpData(d));
        conn.on('close', () => onMpClose());
        conn.send({ type: 'hello', name: state.profile.nickname || 'Гость', avatar: state.profile.avatar, city: state.profile.city, side: 'black' });
        // Guest plays black
        const g = newGame({
          mode: 'online',
          playerSide: BLACK,
          online: { role: 'guest' },
          names: { white: 'Соперник', black: state.profile.nickname || 'Вы' },
          avatars: { white: '👤', black: state.profile.avatar },
        });
