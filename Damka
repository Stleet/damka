  // Roll the prize (also used by roulette to populate filler tiles)
  function rollRandomForBox(type) {
    return rollFromBox(type);
  }

  function _performBoxOpen(type) {
    const btn = document.getElementById('lb-open-btn');
    const stage = document.querySelector('.open-stage');
    if (!stage || !btn) return;
    btn.disabled = true;

    // Determine the real prize
    const result = rollFromBox(type);
    const inv = state.profile.inventory[result.kind];
    const isDuplicate = inv.includes(result.skin.id);
    if (!isDuplicate) inv.push(result.skin.id);
    else state.profile.boxes.cardboard = (state.profile.boxes.cardboard || 0) + 1;
    saveProfile();

    // Build filler tiles using same box drop weights, plant prize at winningIndex
    const WIN_IDX = 35;
    const TOTAL = 48;
    const tiles = [];
    for (let i = 0; i < TOTAL; i++) tiles.push(rollRandomForBox(type));
    tiles[WIN_IDX] = result;

    // Render roulette
    stage.innerHTML = `
      <div class="case-roulette" id="case-roulette">
        <div class="case-marker"></div>
        <div class="case-strip" id="case-strip">
          ${tiles.map((t, i) => `
            <div class="case-tile rarity-${t.rarity}" data-idx="${i}">
              ${skinSwatchHTML(t.kind, t.skin)}
              <div class="name" style="color:${RARITY[t.rarity].color}">${escapeHTML(t.skin.name)}</div>
            </div>
          `).join('')}
        </div>
      </div>
    `;

    const actions = document.querySelector('.modal .modal-actions');
    if (actions) actions.innerHTML = `<div class="muted center grow" style="padding:8px;">Открываем…</div>`;

    Sound.select();

    // Compute target translate so the winning tile lands under the marker
    requestAnimationFrame(() => {
      const strip = document.getElementById('case-strip');
      const roul = document.getElementById('case-roulette');
      const tile = strip.children[WIN_IDX];
      if (!tile || !roul) { renderRevealStage(result, type, isDuplicate); return; }
      const tileRect = tile.getBoundingClientRect();
      const stripRect = strip.getBoundingClientRect();
      const roulRect = roul.getBoundingClientRect();
      const tileCenterRelStrip = (tileRect.left - stripRect.left) + tileRect.width / 2;
      const viewportCenter = roulRect.width / 2;
      // Random jitter within tile (±35% of tile width) so final position varies
      const jitter = (Math.random() - 0.5) * tileRect.width * 0.7;
      const target = viewportCenter - tileCenterRelStrip + jitter;

      // Apply transition and target
      strip.style.transition = 'transform 5.6s cubic-bezier(0.08, 0.7, 0.1, 1)';
      strip.style.transform = `translateX(${target}px)`;

      // Ticking sound at slowing pace
      let elapsed = 0;
      const start = performance.now();
      function scheduleTick() {
        const t = performance.now() - start;
        if (t > 5400) return;
        // Frequency slows from ~40ms to ~600ms
        const progress = Math.min(1, t / 5400);
        const interval = 40 + Math.pow(progress, 1.8) * 560;
        Sound.tick();
        setTimeout(scheduleTick, interval);
      }
      scheduleTick();

      // After scroll ends, highlight winning tile + reveal
      setTimeout(() => {
        tile.classList.add('win-glow');
        if (result.rarity === 'legendary' || result.rarity === 'mythic') Sound.win();
        else if (result.rarity === 'epic') Sound.king();
        else Sound.move();
        setTimeout(() => renderRevealStage(result, type, isDuplicate), 900);
      }, 5700);
    });
  }

