      `<div class="muted center" style="padding:20px; font-size:12px;">Сообщений пока нет</div>`;
  }
  function sendChat(text) {
    text = String(text || '').slice(0, 200).trim();
    if (!text) return;
    if (state.multiplayer && state.multiplayer.conn) {
      try { state.multiplayer.conn.send({ type:'chat', text }); } catch {}
