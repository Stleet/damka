    if (!p.friends) p.friends = [];
    if (!p.lang) p.lang = 'ru';
    // Verify equipped items exist in catalog; fallback to starter
    if (!getSkin('pieces', p.equipped.piece)) p.equipped.piece = 'classic';
    if (!getSkin('boards', p.equipped.board)) p.equipped.board = 'wood';
    return p;
  }
  function saveProfile() { Storage.set('profile', state.profile); }

  function loadLeaderboardLocal() {
    return Storage.get('lb', []);
  }
  function recordResult(result) {
    // result: 'win'|'loss'|'draw'; updates profile stats and leaderboard entry
    const p = state.profile;
    if (result === 'win') {
      p.stats.wins++;
      p.stats.rating = Math.min(2400, p.stats.rating + 18);
    } else if (result === 'loss') {
      p.stats.losses++;
      p.stats.rating = Math.max(400, p.stats.rating - 12);
    } else {
      p.stats.draws++;
    }
    saveProfile();
    const lb = loadLeaderboardLocal();
    const ix = lb.findIndex(e => e.id === 'me');
