        moreBoxes ? `<button class="btn grow" onclick="App._closeOpening(); App.openInventory();">Открыть другие</button>` : ''}
      <button class="btn btn-ghost grow" onclick="App._closeOpening(); App.openInventory();">В инвентарь</button>
    `;
  }

  function _closeOpening() {
    boxOpening = false;
    closeModal();
  }

  function openAllBoxes() {
    // Sequential opening — open them one at a time via the same modal flow.
    // Build the queue in order: cardboard, silver, gold, etc.
    const p = state.profile;
    boxQueue = [];
    for (const t of ['gold','silver','cardboard']) {
      for (let i = 0; i < (p.boxes[t] || 0); i++) boxQueue.push(t);
    }
    if (boxQueue.length === 0) return;
    _processBoxQueue();
  }
  function _processBoxQueue() {
    if (boxQueue.length === 0) { boxOpening = false; openInventory(); return; }
    const next = boxQueue.shift();
    // Wrap original openBox flow but after reveal go to next automatically
    openBox(next);
    // Wait for box opening — patch _closeOpening to continue queue
    // Simpler: user clicks "Открыть" then "Дальше". Reset normal close.
  }

