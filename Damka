<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#0e1218" />
<link rel="manifest" href="manifest.json" />
<link rel="icon" type="image/svg+xml" href="icon.svg" />
<link rel="apple-touch-icon" href="icon.svg" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Дамка" />
<title>Дамка — Шашки с AI-тренером</title>
<style>
  :root {
    --bg: #0e1218;
    --bg-grad: radial-gradient(1200px 700px at 80% -10%, rgba(247,200,115,0.10), transparent 60%),
               radial-gradient(900px 500px at -10% 100%, rgba(85,150,255,0.07), transparent 60%),
               linear-gradient(180deg, #0c1117 0%, #0e1218 100%);
    --surface: #181d26;
    --surface-2: #1f2530;
    --surface-3: #272e3b;
    --text: #ebebeb;
    --text-dim: #9aa3b2;
    --text-faint: #6b7280;
    --accent: #f7c873;
    --accent-2: #c89b3c;
    --accent-grad: linear-gradient(135deg, #f7d486 0%, #d4a242 100%);
    --good: #6ec46a;
    --warn: #ffb84d;
    --bad: #ff7a6b;
    --info: #6ea8fe;
    --board-light: #e8c98f;
    --board-dark: #7a4a26;
    --board-light-2: #efd8a8;
    --board-dark-2: #5c3517;
    --highlight: rgba(247,200,115,0.55);
    --possible: rgba(110, 196, 106, 0.55);
    --capture: rgba(255, 122, 107, 0.65);
    --selected: rgba(247,200,115,0.85);
    --border: rgba(255,255,255,0.07);
    --border-strong: rgba(255,255,255,0.12);
    --shadow: 0 10px 40px rgba(0,0,0,0.45);
    --shadow-soft: 0 4px 16px rgba(0,0,0,0.25);
    --piece-w: linear-gradient(160deg, #f4ecd6 10%, #d8c191 90%);
    --piece-w-edge: #a07f3a;
    --piece-b: linear-gradient(160deg, #3c3c3c 10%, #111 90%);
    --piece-b-edge: #000;
    --king-glow: 0 0 0 2px #f7c873 inset, 0 0 8px rgba(247,200,115,0.5);
    --radius: 14px;
    --radius-sm: 10px;
    --radius-lg: 20px;
  }
  [data-theme="light"] {
    --bg: #f6f1e6;
    --bg-grad: radial-gradient(1200px 700px at 85% -10%, rgba(212,162,66,0.18), transparent 55%),
               radial-gradient(900px 500px at -10% 100%, rgba(85,150,255,0.10), transparent 55%),
               linear-gradient(180deg, #f7f3e8 0%, #f3ecdb 100%);
    --surface: #ffffff;
    --surface-2: #f5efdf;
    --surface-3: #ece3cb;
    --text: #1a1a1a;
    --text-dim: #5b5b5b;
    --text-faint: #8a8a8a;
    --border: rgba(0,0,0,0.07);
    --border-strong: rgba(0,0,0,0.14);
    --shadow: 0 12px 36px rgba(60,40,10,0.10);
    --shadow-soft: 0 4px 14px rgba(60,40,10,0.06);
    --board-light: #f3dcae;
    --board-dark: #a36b3a;
    --board-light-2: #f7e6c2;
    --board-dark-2: #804f24;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; height: 100%; }
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    background-image: var(--bg-grad);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    overflow-x: hidden;
  }
  button { font: inherit; color: inherit; cursor: pointer; border: none; background: none; }
  input, select, textarea { font: inherit; color: inherit; }
  input::placeholder { color: var(--text-faint); }
  a { color: inherit; }

  /* ===== App layout ===== */
  .app { max-width: 1280px; margin: 0 auto; padding: 16px 20px 40px; }

  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 4px 22px;
  }
  .brand {
    display: flex; align-items: center; gap: 12px; font-weight: 700; letter-spacing: 0.2px;
    cursor: pointer;
  }
  .brand-logo {
    width: 38px; height: 38px; border-radius: 11px;
    background: var(--accent-grad);
    display: grid; place-items: center; color: #2a1c00; font-weight: 900; font-size: 20px;
    box-shadow: 0 6px 18px rgba(247,200,115,0.25);
  }
  .brand-title { font-size: 18px; }
  .brand-sub { color: var(--text-dim); font-size: 12px; font-weight: 500; }

  .topbar-right { display: flex; gap: 8px; align-items: center; }
  .iconbtn {
    width: 38px; height: 38px; border-radius: 11px; display: grid; place-items: center;
    background: var(--surface); border: 1px solid var(--border);
    color: var(--text-dim); transition: all 0.15s ease;
  }
  .iconbtn:hover { color: var(--text); background: var(--surface-2); }
  .pro-badge {
    background: var(--accent-grad); color: #2a1c00; padding: 6px 12px; border-radius: 99px;
    font-weight: 700; font-size: 12px; letter-spacing: 0.3px;
  }

  /* ===== Buttons ===== */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 12px 20px; border-radius: var(--radius-sm);
    background: var(--surface-2); border: 1px solid var(--border); color: var(--text);
    font-weight: 600; font-size: 14px; transition: all 0.15s ease;
    white-space: nowrap;
  }
  .btn:hover:not(:disabled) { background: var(--surface-3); transform: translateY(-1px); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-primary { background: var(--accent-grad); color: #2a1c00; border: none; font-weight: 700; }
  .btn-primary:hover:not(:disabled) { box-shadow: 0 8px 24px rgba(247,200,115,0.35); transform: translateY(-1px); }
  .btn-ghost { background: transparent; border: 1px solid var(--border-strong); }
  .btn-ghost:hover:not(:disabled) { background: var(--surface-2); }
  .btn-danger { background: rgba(255,122,107,0.12); color: var(--bad); border: 1px solid rgba(255,122,107,0.25); }
  .btn-sm { padding: 8px 14px; font-size: 13px; }
  .btn-lg { padding: 14px 26px; font-size: 15px; }

  /* ===== Onboarding ===== */
  .onb {
    display: grid; place-items: center; min-height: calc(100vh - 80px); padding: 20px;
  }
  .onb-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 36px 32px; max-width: 480px; width: 100%;
    box-shadow: var(--shadow);
    text-align: center;
  }
  .onb-logo {
    width: 72px; height: 72px; border-radius: 22px;
    background: var(--accent-grad);
    margin: 0 auto 20px; display: grid; place-items: center;
    font-size: 36px; font-weight: 900; color: #2a1c00;
    box-shadow: 0 10px 30px rgba(247,200,115,0.3);
  }
  .onb h1 { font-size: 28px; margin: 0 0 8px; }
  .onb .sub { color: var(--text-dim); margin-bottom: 28px; font-size: 15px; }
  .field { text-align: left; margin-bottom: 14px; }
  .field label { display: block; font-size: 12px; color: var(--text-dim); margin-bottom: 6px; font-weight: 600; letter-spacing: 0.3px; text-transform: uppercase; }
  .field input, .field select {
    width: 100%; padding: 12px 14px; border-radius: var(--radius-sm);
    background: var(--surface-2); border: 1px solid var(--border); color: var(--text);
    outline: none; transition: border-color 0.15s;
  }
  .field input:focus, .field select:focus { border-color: var(--accent); }
  .avatar-picker { display: flex; gap: 8px; flex-wrap: wrap; }
  .avatar-opt {
    width: 44px; height: 44px; border-radius: 12px;
    background: var(--surface-2); border: 2px solid transparent;
    display: grid; place-items: center; font-size: 24px;
    transition: all 0.15s;
  }
  .avatar-opt.sel { border-color: var(--accent); background: var(--surface-3); }
  .avatar-opt:hover { transform: scale(1.08); }

  /* ===== Menu ===== */
  .menu-hero {
    text-align: center; padding: 40px 0 32px;
  }
  .menu-hero h2 { font-size: clamp(28px, 4vw, 42px); margin: 0 0 8px; letter-spacing: -0.5px; }
  .menu-hero .accent { background: var(--accent-grad); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .menu-hero p { color: var(--text-dim); max-width: 540px; margin: 0 auto; font-size: 16px; }

  .modes-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px; margin: 20px 0;
  }
  .mode-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 22px;
    cursor: pointer; transition: all 0.2s ease;
    position: relative; overflow: hidden;
    text-align: left;
    min-height: 160px;
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .mode-card:hover { transform: translateY(-3px); border-color: var(--border-strong); box-shadow: var(--shadow-soft); }
  .mode-card.featured { border-color: rgba(247,200,115,0.35); background: linear-gradient(180deg, rgba(247,200,115,0.06), var(--surface)); }
  .mode-card.featured::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(400px 200px at 100% 0%, rgba(247,200,115,0.10), transparent);
    pointer-events: none;
  }
  .mode-emoji { font-size: 30px; }
  .mode-title { font-weight: 700; font-size: 17px; margin: 14px 0 6px; display: flex; align-items: center; gap: 8px; }
  .mode-desc { color: var(--text-dim); font-size: 13.5px; line-height: 1.45; }
  .mode-cta { display: inline-flex; align-items: center; gap: 6px; color: var(--accent); font-weight: 600; font-size: 13px; margin-top: 14px; }
  .mode-tag { font-size: 10px; padding: 3px 8px; border-radius: 99px; background: var(--surface-2); color: var(--text-dim); font-weight: 600; letter-spacing: 0.4px; text-transform: uppercase; }
  .mode-tag.hot { background: rgba(255,122,107,0.16); color: var(--bad); }
  .mode-tag.new { background: rgba(110,196,106,0.16); color: var(--good); }
  .mode-tag.pro { background: var(--accent-grad); color: #2a1c00; }

  .stats-strip {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px; margin: 28px 0 8px;
  }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    padding: 16px; border-radius: var(--radius);
  }
  .stat-val { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; }
  .stat-label { font-size: 12px; color: var(--text-dim); margin-top: 2px; letter-spacing: 0.3px; text-transform: uppercase; font-weight: 600; }

  /* ===== Game screen ===== */
  .game-layout {
    display: grid; grid-template-columns: 1fr 320px; gap: 20px;
    align-items: start;
  }
  .game-main { display: flex; flex-direction: column; gap: 14px; }
  .player-strip {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
  }
  .player-strip.active { border-color: rgba(247,200,115,0.45); box-shadow: 0 0 0 1px rgba(247,200,115,0.25); }
  .player-info { display: flex; align-items: center; gap: 12px; }
  .player-avatar {
    width: 40px; height: 40px; border-radius: 12px;
    background: var(--surface-2); display: grid; place-items: center; font-size: 22px;
  }
  .player-name { font-weight: 700; font-size: 14px; }
  .player-meta { font-size: 11.5px; color: var(--text-dim); }
  .player-clock {
    font-variant-numeric: tabular-nums; font-weight: 700; font-size: 18px;
    padding: 6px 12px; background: var(--surface-2); border-radius: 8px;
    letter-spacing: 0.5px;
  }
  .player-clock.low { color: var(--bad); animation: pulse 1s infinite; }
  @keyframes pulse { 0%,100% {opacity:1;} 50% {opacity:0.6;} }
  .player-captures { display: inline-flex; gap: 2px; align-items: center; font-size: 12px; color: var(--text-dim); }

  /* ===== Board ===== */
  .board-wrap {
    aspect-ratio: 1/1;
    background: linear-gradient(135deg, var(--board-dark-2), var(--board-dark));
    border-radius: var(--radius);
    padding: 16px;
    box-shadow: var(--shadow);
    position: relative;
    user-select: none;
  }
  .board {
    width: 100%; height: 100%;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(0,0,0,0.3);
  }
  .cell {
    position: relative;
    display: grid; place-items: center;
  }
  .cell.light { background: var(--board-light); }
  .cell.dark { background: var(--board-dark); }
  .cell-mark {
    position: absolute; top: 2px; left: 4px;
    font-size: 9px; color: rgba(0,0,0,0.35); font-weight: 700;
    pointer-events: none;
  }
  [data-theme="light"] .cell-mark { color: rgba(0,0,0,0.4); }
  .cell.light .cell-mark { color: rgba(120,80,40,0.55); }
  .cell.dark .cell-mark { color: rgba(255,235,180,0.4); }
  .cell-hl-selected::after,
  .cell-hl-possible::after,
  .cell-hl-capture::after,
  .cell-hl-last::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
  }
  .cell-hl-selected::after { background: var(--selected); mix-blend-mode: overlay; }
  .cell-hl-last::after { background: rgba(247,200,115,0.20); }
  .cell-hl-possible::before {
    content: ''; position: absolute; width: 26%; height: 26%; border-radius: 50%;
    background: var(--possible); pointer-events: none;
  }
  .cell-hl-capture::before {
    content: ''; position: absolute; width: 80%; height: 80%; border-radius: 50%;
    border: 4px solid var(--capture); box-sizing: border-box; pointer-events: none;
  }

  .piece {
    width: 80%; height: 80%; border-radius: 50%;
    display: grid; place-items: center;
    cursor: pointer;
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    z-index: 2;
  }
  .piece.w {
    background: var(--piece-w);
    box-shadow:
      inset 0 -3px 5px rgba(0,0,0,0.18),
      inset 0 2px 4px rgba(255,255,255,0.55),
      0 4px 10px rgba(0,0,0,0.25),
      0 0 0 2px var(--piece-w-edge);
  }
  .piece.b {
    background: var(--piece-b);
    box-shadow:
      inset 0 -3px 5px rgba(0,0,0,0.5),
      inset 0 2px 4px rgba(255,255,255,0.10),
      0 4px 10px rgba(0,0,0,0.4),
      0 0 0 2px var(--piece-b-edge);
  }
  .piece.king::after {
    content: '♛'; font-size: 60%; line-height: 1;
    color: var(--accent); text-shadow: 0 1px 1px rgba(0,0,0,0.4);
  }
  .piece.b.king::after { color: var(--accent); }
  .piece.draggable:hover { transform: scale(1.05); box-shadow: var(--shadow); }
  .piece.selected { transform: scale(1.08); }
  .piece.selected.w { box-shadow: 0 0 0 3px var(--accent), inset 0 -3px 5px rgba(0,0,0,0.18), 0 6px 16px rgba(0,0,0,0.3); }
  .piece.selected.b { box-shadow: 0 0 0 3px var(--accent), inset 0 -3px 5px rgba(0,0,0,0.5), 0 6px 16px rgba(0,0,0,0.4); }
  .piece.must { animation: bob 1.4s infinite; }
  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }

  /* ===== Inventory / Boxes / Rarities ===== */
  .rarity-bar {
    display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 14px;
  }
  .rarity-chip {
    padding: 4px 10px; border-radius: 99px; font-size: 11px; font-weight: 700;
    cursor: pointer; border: 1px solid var(--border); background: var(--surface-2);
    transition: all 0.15s;
  }
  .rarity-chip.active { background: var(--surface-3); border-color: var(--border-strong); }

  .inv-tabs { display: flex; gap: 4px; background: var(--surface-2); padding: 4px; border-radius: 10px; margin-bottom: 14px; }
  .inv-tab { flex: 1; padding: 8px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; color: var(--text-dim); cursor: pointer; text-align: center; }
  .inv-tab.active { background: var(--surface); color: var(--text); box-shadow: var(--shadow-soft); }

  .inv-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 10px;
  }
  .inv-tile {
    background: var(--surface-2);
    border: 2px solid var(--border);
    border-radius: 12px;
    padding: 10px;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;
    position: relative; overflow: hidden;
    min-height: 130px;
  }
  .inv-tile:hover { transform: translateY(-2px); }
  .inv-tile.locked { opacity: 0.35; filter: grayscale(0.85); cursor: default; }
  .inv-tile.locked:hover { transform: none; }
  .inv-tile.equipped::before {
    content: '✓ В игре'; position: absolute; top: 6px; right: 6px;
    background: var(--accent-grad); color: #2a1c00; padding: 2px 6px;
    border-radius: 99px; font-size: 9px; font-weight: 800; letter-spacing: 0.3px; z-index: 2;
  }
  .inv-tile.rarity-common    { border-color: #6a7282; box-shadow: 0 0 12px rgba(154,163,178,0.18); }
  .inv-tile.rarity-rare      { border-color: #5dbb63; box-shadow: 0 0 14px rgba(93,187,99,0.25); }
  .inv-tile.rarity-epic      { border-color: #a45ed0; box-shadow: 0 0 16px rgba(164,94,208,0.32); }
  .inv-tile.rarity-mythic    { border-color: #ef4444; box-shadow: 0 0 18px rgba(239,68,68,0.38); }
  .inv-tile.rarity-legendary { border-color: #f7c873; box-shadow: 0 0 22px rgba(247,200,115,0.48); animation: legendaryPulse 2.5s ease-in-out infinite; }
  @keyframes legendaryPulse {
    0%,100% { box-shadow: 0 0 22px rgba(247,200,115,0.40); }
    50%     { box-shadow: 0 0 30px rgba(247,200,115,0.65); }
  }
  .inv-name { font-size: 12.5px; font-weight: 700; text-align: center; line-height: 1.2; }
  .inv-rarity-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .inv-rarity-label.common    { color: #9aa3b2; }
  .inv-rarity-label.rare      { color: #5dbb63; }
  .inv-rarity-label.epic      { color: #a45ed0; }
  .inv-rarity-label.mythic    { color: #ef4444; }
  .inv-rarity-label.legendary { color: #f7c873; }

  /* Skin swatches (piece) */
  .swatch-piece-pair {
    width: 70px; height: 40px; display: grid; grid-template-columns: 1fr 1fr;
    gap: 4px; align-items: center; padding: 4px;
  }
  .swatch-piece {
    width: 100%; aspect-ratio: 1; border-radius: 50%;
    background: var(--sp-bg, #ccc);
    box-shadow:
      inset 0 -2px 3px rgba(0,0,0,0.2),
      inset 0 1px 2px rgba(255,255,255,0.4),
      0 0 0 1.5px var(--sp-edge, #888),
      0 2px 4px rgba(0,0,0,0.25);
  }

  /* Skin swatches (board) */
  .swatch-board {
    width: 70px; height: 40px;
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    border-radius: 4px; overflow: hidden;
    border: 2px solid var(--sb-frame, #444);
  }
  .swatch-board > div { width: 100%; height: 100%; }

  /* Box display */
  .boxes-strip {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 14px;
  }
  .box-card {
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: 12px; padding: 14px 10px; text-align: center;
    cursor: pointer; transition: all 0.15s; position: relative;
  }
  .box-card:hover:not(.empty) { transform: translateY(-2px); background: var(--surface-3); }
  .box-card.empty { opacity: 0.55; cursor: default; }
  .box-card .icon { font-size: 38px; line-height: 1; margin-bottom: 4px;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3)); }
  .box-card .name { font-size: 12px; font-weight: 700; }
  .box-card .count { font-size: 18px; font-weight: 800; color: var(--accent); margin-top: 2px; font-variant-numeric: tabular-nums; }
  .box-card.has-some { border-color: var(--accent); box-shadow: 0 0 16px rgba(247,200,115,0.18); animation: boxPulse 2s infinite; }
  @keyframes boxPulse {
    0%,100% { box-shadow: 0 0 16px rgba(247,200,115,0.18); }
    50%     { box-shadow: 0 0 26px rgba(247,200,115,0.35); }
  }
  .box-card .badge {
    position: absolute; top: 6px; right: 6px;
    background: var(--bad); color: #fff; border-radius: 99px;
    min-width: 18px; height: 18px; padding: 0 5px; font-size: 11px; font-weight: 800;
    display: grid; place-items: center;
  }

  /* Box opening modal */
  .open-stage { text-align: center; padding: 14px 0 8px; min-height: 280px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .lootbox-big {
    width: 140px; height: 140px;
    display: grid; place-items: center;
    font-size: 96px; line-height: 1;
    filter: drop-shadow(0 14px 22px rgba(0,0,0,0.4));
    position: relative;
  }
  .lootbox-big::after {
    content: ''; position: absolute; inset: -30px; border-radius: 50%;
    background: radial-gradient(circle, var(--bx-glow, rgba(247,200,115,0.4)) 0%, transparent 65%);
    z-index: -1; opacity: 0.7;
  }
  .lootbox-big.cardboard { --bx-glow: rgba(201,168,120,0.4); }
  .lootbox-big.silver    { --bx-glow: rgba(216,220,224,0.5); }
  .lootbox-big.gold      { --bx-glow: rgba(247,200,115,0.7); animation: legendaryPulse 1.6s ease-in-out infinite; }
  .lootbox-big.shake { animation: boxShake 0.5s 4; }
  @keyframes boxShake {
    0%,100% { transform: translateX(0) rotate(0); }
    25%     { transform: translateX(-8px) rotate(-5deg); }
    75%     { transform: translateX(8px)  rotate(5deg); }
  }
  .lootbox-big.burst { animation: boxBurst 0.45s forwards; }
  @keyframes boxBurst {
    0%   { transform: scale(1)   rotate(0);   opacity: 1; filter: brightness(1); }
    50%  { transform: scale(1.5) rotate(20deg); opacity: 1; filter: brightness(3); }
    100% { transform: scale(2.4) rotate(40deg); opacity: 0; filter: brightness(5); }
  }

  .reveal-tile {
    opacity: 0; transform: scale(0.6);
    animation: revealIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    padding: 20px; border-radius: 18px;
    display: flex; flex-direction: column; align-items: center; gap: 12px;
  }
  .reveal-tile.rarity-common    { background: radial-gradient(circle at 50% 20%, rgba(154,163,178,0.20), transparent 70%); }
  .reveal-tile.rarity-rare      { background: radial-gradient(circle at 50% 20%, rgba(93,187,99,0.25),  transparent 70%); }
  .reveal-tile.rarity-epic      { background: radial-gradient(circle at 50% 20%, rgba(164,94,208,0.30), transparent 70%); }
  .reveal-tile.rarity-mythic    { background: radial-gradient(circle at 50% 20%, rgba(239,68,68,0.35),  transparent 70%); }
  .reveal-tile.rarity-legendary { background: radial-gradient(circle at 50% 20%, rgba(247,200,115,0.45), transparent 70%); }
  @keyframes revealIn {
    to { opacity: 1; transform: scale(1); }
  }
  .reveal-big-swatch { padding: 14px; border-radius: 14px; border: 2px solid; }
  .reveal-big-swatch.rarity-common    { border-color: #6a7282; }
  .reveal-big-swatch.rarity-rare      { border-color: #5dbb63; }
  .reveal-big-swatch.rarity-epic      { border-color: #a45ed0; }
  .reveal-big-swatch.rarity-mythic    { border-color: #ef4444; }
  .reveal-big-swatch.rarity-legendary { border-color: #f7c873; }
  .reveal-big-swatch .swatch-piece-pair { width: 120px; height: 60px; }
  .reveal-big-swatch .swatch-board { width: 120px; height: 60px; }
  .reveal-rarity {
    font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.2px;
  }
  .reveal-name { font-size: 22px; font-weight: 800; }
  .reveal-meta { font-size: 12px; color: var(--text-dim); }
  .reveal-dup  { font-size: 12px; color: var(--warn); font-weight: 600; }

  /* ===== Case roulette (CS:GO-style) ===== */
  .drop-chances {
    display: flex; gap: 4px; margin: 14px 0 18px;
    border-radius: 8px; overflow: hidden; height: 28px;
  }
  .drop-seg {
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.4);
  }
  .drop-legend { display: flex; gap: 12px; flex-wrap: wrap; font-size: 11px; margin-bottom: 14px; justify-content: center; }
  .drop-legend .leg-item { display: inline-flex; align-items: center; gap: 6px; }
  .drop-legend .leg-dot { width: 10px; height: 10px; border-radius: 3px; }

  .case-roulette {
    width: 100%;
    height: 152px;
    overflow: hidden;
    position: relative;
    border-radius: 12px;
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
    border: 1px solid var(--border-strong);
    box-shadow: inset 0 0 30px rgba(0,0,0,0.4);
    margin: 14px 0;
  }
  .case-roulette::before, .case-roulette::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 80px; z-index: 4; pointer-events: none;
  }
  .case-roulette::before { left: 0;
    background: linear-gradient(to right, var(--surface) 10%, rgba(0,0,0,0) 100%); }
  .case-roulette::after { right: 0;
    background: linear-gradient(to left, var(--surface) 10%, rgba(0,0,0,0) 100%); }
  .case-marker {
    position: absolute; top: 0; bottom: 0; left: 50%; width: 3px;
    background: var(--accent); z-index: 3; transform: translateX(-1.5px);
    box-shadow: 0 0 14px rgba(247,200,115,0.7);
  }
  .case-marker::before, .case-marker::after {
    content: ''; position: absolute; left: -8px; width: 18px; height: 12px;
    background: var(--accent);
  }
  .case-marker::before { top: 0; clip-path: polygon(50% 100%, 100% 0, 0 0); }
  .case-marker::after  { bottom: 0; clip-path: polygon(50% 0, 100% 100%, 0 100%); }
  .case-strip {
    display: flex;
    height: 100%;
    align-items: center;
    will-change: transform;
    padding: 8px 0;
  }
  .case-tile {
    flex: 0 0 110px;
    height: 136px;
    margin: 0 3px;
    border-radius: 10px;
    border: 2px solid;
    background: var(--surface);
    display: flex; flex-direction: column; align-items: center; justify-content: space-between;
    padding: 10px 6px 8px;
    box-sizing: border-box;
    position: relative; overflow: hidden;
  }
  .case-tile::before {
    content: ''; position: absolute; inset: 0;
    background: var(--tile-glow, transparent);
    opacity: 0.25; pointer-events: none;
  }
  .case-tile.rarity-common    { border-color: #6a7282; --tile-glow: linear-gradient(180deg, rgba(154,163,178,0.12), transparent); }
  .case-tile.rarity-rare      { border-color: #5dbb63; --tile-glow: linear-gradient(180deg, rgba(93,187,99,0.20), transparent); }
  .case-tile.rarity-epic      { border-color: #a45ed0; --tile-glow: linear-gradient(180deg, rgba(164,94,208,0.25), transparent); }
  .case-tile.rarity-mythic    { border-color: #ef4444; --tile-glow: linear-gradient(180deg, rgba(239,68,68,0.30), transparent); }
  .case-tile.rarity-legendary { border-color: #f7c873; --tile-glow: linear-gradient(180deg, rgba(247,200,115,0.40), transparent); }
  .case-tile .name {
    font-size: 11px; font-weight: 700; text-align: center; line-height: 1.15;
    text-shadow: 0 1px 2px rgba(0,0,0,0.4);
  }
  .case-tile.win-glow {
    animation: winFlash 0.4s ease-in-out 3 alternate;
  }
  @keyframes winFlash {
    from { filter: brightness(1); }
    to   { filter: brightness(1.8); }
  }

  /* ===== Story / Campaign ===== */
  .camp-header {
    display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
  }
  .camp-header h2 { margin: 0; font-size: 26px; }
  .worlds-list { display: flex; flex-direction: column; gap: 18px; }
  .world-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }
  .world-card.locked { opacity: 0.55; }
  .world-head {
    display: flex; align-items: center; gap: 14px; padding: 16px 18px;
    background: linear-gradient(135deg, var(--world-color, #3a5a8a), var(--world-color-2, #1a2a5a));
    color: #fff;
    position: relative;
  }
  .world-head .emoji { font-size: 38px; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3)); }
  .world-head .title { font-size: 19px; font-weight: 800; letter-spacing: -0.2px; }
  .world-head .desc { font-size: 12.5px; opacity: 0.85; margin-top: 2px; }
  .world-head .progress {
    margin-left: auto;
    font-weight: 700;
    background: rgba(0,0,0,0.25); padding: 6px 12px; border-radius: 99px; font-size: 13px;
    backdrop-filter: blur(8px);
  }
  .world-map {
    position: relative; height: 280px;
    background:
      radial-gradient(circle at 20% 80%, rgba(255,255,255,0.06) 0%, transparent 30%),
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.04) 0%, transparent 30%),
      linear-gradient(180deg, rgba(0,0,0,0.10), rgba(0,0,0,0.20)),
      linear-gradient(135deg, var(--world-color, #3a5a8a) 0%, var(--world-color-2, #1a2a5a) 100%);
    overflow: hidden;
  }
  .map-bg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .map-node {
    position: absolute; transform: translate(-50%, -50%);
    text-align: center; cursor: pointer; transition: transform 0.15s;
    z-index: 2;
    width: 80px;
  }
  .map-node:hover.available { transform: translate(-50%, -50%) scale(1.1); }
  .map-node .circle {
    width: 54px; height: 54px; margin: 0 auto;
    border-radius: 50%;
    display: grid; place-items: center;
    font-size: 28px;
    background: rgba(255,255,255,0.95);
    border: 3px solid #fff;
    box-shadow: 0 6px 14px rgba(0,0,0,0.35);
  }
  .map-node.locked { cursor: default; }
  .map-node.locked .circle {
    background: rgba(40,40,40,0.85); color: #888;
    border-color: rgba(255,255,255,0.2);
    font-size: 22px;
  }
  .map-node.completed .circle {
    background: linear-gradient(135deg, #80e090, #4aa860);
    border-color: #aef2bc;
    box-shadow: 0 6px 14px rgba(74,168,96,0.5);
  }
  .map-node.available .circle {
    background: linear-gradient(135deg, #ffe18c, #f5a83b);
    border-color: #ffdf80;
    box-shadow: 0 6px 18px rgba(245,168,59,0.55);
    animation: nodePulse 1.5s ease-in-out infinite;
  }
  @keyframes nodePulse {
    0%,100% { box-shadow: 0 6px 18px rgba(245,168,59,0.45); }
    50%     { box-shadow: 0 6px 24px rgba(245,168,59,0.75); }
  }
  .map-node.boss .circle {
    width: 70px; height: 70px; font-size: 36px;
    border-width: 4px;
  }
  .map-node.boss.available .circle {
    background: linear-gradient(135deg, #ff7a6b, #d8434c);
    border-color: #ffb0a8;
    box-shadow: 0 6px 22px rgba(216,67,76,0.65);
  }
  .map-node .name {
    font-size: 11.5px; font-weight: 700; color: #fff;
    margin-top: 6px; text-shadow: 0 1px 3px rgba(0,0,0,0.6);
  }
  .map-node .rating {
    font-size: 10px; color: rgba(255,255,255,0.75); margin-top: 1px;
  }
  .map-node.completed .name::after { content: ' ✓'; color: #aef2bc; }
  .map-node.boss .name { color: #ffd0c8; }
  .world-card.locked .world-head { filter: grayscale(0.6); }
  .world-locked-cta {
    padding: 30px; text-align: center; color: var(--text-dim); font-size: 14px;
  }

  /* Puzzle board (mini) */
  .puz-board {
    width: 100%; max-width: 360px; aspect-ratio: 1/1;
    margin: 0 auto 14px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    border-radius: 8px; overflow: hidden;
    box-shadow: 0 6px 18px rgba(0,0,0,0.3);
    border: 4px solid var(--board-dark-2, #5c3517);
    user-select: none;
  }
  .puz-cell { position: relative; display: grid; place-items: center; cursor: pointer; }
  .puz-cell.light { background: var(--board-light, #e8c98f); }
  .puz-cell.dark  { background: var(--board-dark, #7a4a26); }
  .puz-cell.sel::after {
    content: ''; position: absolute; inset: 0; background: rgba(247,200,115,0.45);
  }
  .puz-cell.target::before {
    content: ''; position: absolute; width: 30%; height: 30%; border-radius: 50%;
    background: rgba(110,196,106,0.65); pointer-events: none;
  }
  .puz-cell.target.cap::before {
    width: 0; height: 0; background: transparent;
    border: 3px solid rgba(255,122,107,0.7); border-radius: 50%;
    inset: 12%; box-sizing: border-box;
  }
  .puz-piece {
    width: 78%; height: 78%; border-radius: 50%;
    pointer-events: none; position: relative; z-index: 1;
  }
  .puz-piece.w {
    background: var(--piece-w, linear-gradient(160deg, #f4ecd6 10%, #d8c191 90%));
    box-shadow: inset 0 -2px 4px rgba(0,0,0,0.2), inset 0 1px 3px rgba(255,255,255,0.5),
                0 3px 6px rgba(0,0,0,0.25), 0 0 0 2px var(--piece-w-edge, #a07f3a);
  }
  .puz-piece.b {
    background: var(--piece-b, linear-gradient(160deg, #3c3c3c 10%, #111 90%));
    box-shadow: inset 0 -2px 4px rgba(0,0,0,0.5), 0 3px 6px rgba(0,0,0,0.4),
                0 0 0 2px var(--piece-b-edge, #000);
  }
  .puz-piece.king::after {
    content: '♛'; position: absolute; inset: 0; display: grid; place-items: center;
    font-size: 55%; line-height: 1; color: var(--accent); text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }
  .puz-prompt { padding: 8px 4px 4px; text-align: center; font-size: 14px; }
  .puz-prompt .muted { font-size: 12px; margin-top: 4px; }
  .puz-stats-strip {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 12px;
  }
  .puz-stat { background: var(--surface-2); padding: 10px 8px; border-radius: 10px; text-align: center; }
  .puz-stat .v { font-size: 20px; font-weight: 800; }
  .puz-stat .l { font-size: 11px; color: var(--text-dim); margin-top: 2px; }

  /* Chat panel (multiplayer) */
  .chat-panel { display: flex; flex-direction: column; max-height: 240px; }
  .chat-msgs {
    flex: 1; overflow-y: auto; padding: 4px 2px;
    display: flex; flex-direction: column; gap: 6px; min-height: 100px;
  }
  .chat-msg {
    padding: 6px 10px; border-radius: 10px; max-width: 88%;
    font-size: 13px; line-height: 1.3;
    word-wrap: break-word; word-break: break-word;
  }
  .chat-msg.me   { background: var(--accent-grad); color: #2a1c00; align-self: flex-end; }
  .chat-msg.them { background: var(--surface-2); color: var(--text); align-self: flex-start; }
  .chat-input-row { display: flex; gap: 6px; margin-top: 8px; }
  .chat-input-row input {
    flex: 1; padding: 8px 12px; background: var(--surface-2); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text); font-size: 13px;
  }
  .chat-quick { display: flex; gap: 4px; margin-top: 6px; flex-wrap: wrap; }
  .chat-quick button {
    padding: 4px 8px; font-size: 14px; background: var(--surface-2);
    border: 1px solid var(--border); border-radius: 99px;
  }

  /* Tournament bracket */
  .bracket {
    display: flex; gap: 30px; padding: 14px 8px; overflow-x: auto;
    align-items: stretch;
  }
  .bracket-round {
    display: flex; flex-direction: column; justify-content: space-around;
    gap: 14px; min-width: 160px;
  }
  .bracket-match {
    background: var(--surface-2); border: 1px solid var(--border); border-radius: 10px;
    padding: 8px 10px; font-size: 13px; min-height: 60px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .bracket-match.playable { border-color: var(--accent); cursor: pointer; }
  .bracket-match.playable:hover { background: var(--surface-3); }
  .bracket-player { padding: 3px 4px; }
  .bracket-player.win { font-weight: 800; color: var(--good); }
  .bracket-player.lose { color: var(--text-faint); text-decoration: line-through; }
  .bracket-sep { border-top: 1px solid var(--border); margin: 2px 0; }

  /* Friends list */
  .friend-row {
    display: flex; align-items: center; gap: 12px; padding: 10px 4px;
    border-bottom: 1px solid var(--border);
  }
  .friend-row:last-child { border-bottom: none; }
  .friend-avatar {
    width: 36px; height: 36px; border-radius: 10px; background: var(--surface-2);
    display: grid; place-items: center; font-size: 20px; flex-shrink: 0;
  }
  .friend-meta { flex: 1; min-width: 0; }
  .friend-name { font-weight: 700; font-size: 14px; }
  .friend-sub { font-size: 11.5px; color: var(--text-dim); }

  /* Cloud LB config */
  .cloud-banner {
    background: linear-gradient(135deg, rgba(110,168,254,0.15), rgba(122,200,255,0.05));
    border: 1px solid rgba(110,168,254,0.30); border-radius: 10px;
    padding: 10px 12px; font-size: 12.5px; margin-bottom: 12px;
    display: flex; align-items: center; gap: 10px;
  }
  .cloud-banner.online { background: linear-gradient(135deg, rgba(110,196,106,0.18), rgba(110,196,106,0.05)); border-color: rgba(110,196,106,0.40); }

  /* Campaign banner inside game screen */
  .camp-banner {
    background: linear-gradient(135deg, var(--world-color, #3a5a8a), var(--world-color-2, #1a2a5a));
    color: #fff; padding: 12px 14px; border-radius: var(--radius);
    display: flex; align-items: center; gap: 10px;
    font-size: 13px;
  }
  .camp-banner .emoji { font-size: 20px; }
  .camp-banner strong { font-weight: 700; }

  /* ===== Sidebar ===== */
  .sidebar { display: flex; flex-direction: column; gap: 14px; }
  .panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 16px;
  }
  .panel h3 { margin: 0 0 12px; font-size: 13px; letter-spacing: 0.5px; text-transform: uppercase; color: var(--text-dim); }
  .moves-list {
    max-height: 280px; overflow-y: auto; font-size: 13px;
    display: grid; grid-template-columns: 24px 1fr 1fr; gap: 4px 8px;
    font-variant-numeric: tabular-nums;
  }
  .moves-list::-webkit-scrollbar { width: 6px; }
  .moves-list::-webkit-scrollbar-thumb { background: var(--surface-3); border-radius: 3px; }
  .moves-list .turn-num { color: var(--text-faint); padding: 2px 0; }
  .moves-list .mv {
    padding: 2px 6px; border-radius: 5px; cursor: pointer;
    transition: background 0.1s; color: var(--text);
  }
  .moves-list .mv:hover { background: var(--surface-2); }
  .moves-list .mv.cur { background: var(--surface-3); color: var(--accent); font-weight: 600; }

  .ctrls { display: flex; gap: 8px; flex-wrap: wrap; }
  .ctrls .btn { flex: 1; min-width: 100px; }

  /* ===== Modal ===== */
  .modal-bg {
    position: fixed; inset: 0; background: rgba(0,0,0,0.55);
    display: grid; place-items: center; padding: 20px; z-index: 100;
    animation: fadeIn 0.2s ease;
    backdrop-filter: blur(4px);
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .modal {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 28px; max-width: 540px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    box-shadow: var(--shadow);
    animation: popIn 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes popIn { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .modal h2 { margin: 0 0 6px; font-size: 22px; }
  .modal .modal-sub { color: var(--text-dim); margin-bottom: 18px; font-size: 14px; }
  .modal-close {
    position: absolute; top: 16px; right: 16px;
    width: 32px; height: 32px; border-radius: 8px; background: var(--surface-2);
    display: grid; place-items: center; color: var(--text-dim);
  }
  .modal-row { display: flex; gap: 10px; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); }
  .modal-row:last-child { border-bottom: none; }
  .modal-actions { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
  .modal-actions .btn { flex: 1; }

  /* Result modal */
  .result-emoji { font-size: 56px; text-align: center; margin-bottom: 4px; }
  .result-title { font-size: 24px; font-weight: 800; text-align: center; }
  .result-sub { color: var(--text-dim); text-align: center; margin: 4px 0 18px; }
  .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .result-stat { background: var(--surface-2); padding: 12px; border-radius: 10px; text-align: center; }
  .result-stat .v { font-size: 22px; font-weight: 800; }
  .result-stat .l { font-size: 11px; color: var(--text-dim); margin-top: 2px; }

  /* Share modal */
  .share-link-row { display: flex; gap: 8px; margin-bottom: 10px; }
  .share-link-row input { flex: 1; background: var(--surface-2); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; color: var(--text); font-family: ui-monospace, Menlo, monospace; font-size: 13px; }

  /* Toast */
  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    background: var(--surface-3); border: 1px solid var(--border-strong);
    color: var(--text); padding: 12px 18px; border-radius: 99px;
    box-shadow: var(--shadow); z-index: 200;
    animation: toastIn 0.3s ease, toastOut 0.3s ease 2.4s forwards;
    font-size: 14px; font-weight: 500;
  }
  @keyframes toastIn { from { transform: translate(-50%, 30px); opacity: 0; } to { transform: translate(-50%, 0); opacity: 1; } }
  @keyframes toastOut { to { transform: translate(-50%, 30px); opacity: 0; } }

  /* ===== AI Coach / Analysis ===== */
  .analysis-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .analysis-card { background: var(--surface-2); padding: 14px; border-radius: 10px; }
  .analysis-card .v { font-size: 22px; font-weight: 800; }
  .analysis-card .l { font-size: 12px; color: var(--text-dim); margin-top: 2px; }
  .accuracy-bar {
    height: 8px; background: var(--surface-2); border-radius: 4px;
    overflow: hidden; margin-top: 8px; position: relative;
  }
  .accuracy-bar-fill {
    height: 100%; background: linear-gradient(90deg, var(--bad), var(--warn), var(--good));
    border-radius: 4px; transition: width 0.6s ease;
  }
  .move-tape {
