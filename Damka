  function puzzleClick(r, c) {
    const pz = state._puzzle; if (!pz || pz.done) return;
    const piece = pz.board[r][c];
    if (pz.selected) {
      const moves = legalMoves(pz.board, pz.puz.side);
      const match = moves.find(m =>
        m.steps[0][0] === pz.selected[0] && m.steps[0][1] === pz.selected[1] &&
        m.steps[m.steps.length-1][0] === r && m.steps[m.steps.length-1][1] === c
      );
      if (match) {
        const fromSol = pz.puz.solution.from, toSol = pz.puz.solution.to;
        const correct = pz.selected[0]===fromSol[0] && pz.selected[1]===fromSol[1] && r===toSol[0] && c===toSol[1];
        if (correct) {
          pz.board = applyMove(pz.board, match);
          pz.selected = null; pz.done = true;
          const newRecord = recordPuzzleSolved();
          Sound.win();
          refreshPuzBoard();
          const streak = state.profile.puzzleProgress.streak;
          document.getElementById('puz-prompt').innerHTML =
            `<div style="color:var(--good); font-weight:800; font-size:16px;">${t('puzzle_correct')}</div>
             ${newRecord ? `<div class="reward-display rarity-epic" style="margin-top:12px;">
                <div class="reward-icon-wrap"><div class="reward-icon">🎁</div></div>
                <div class="reward-text">
                  <div class="reward-title">+1 ${BOX_TYPES.silver.name} коробка</div>
                  <div class="reward-sub">Серия дней: ${streak}. Откройте в инвентаре 🎒</div>
                </div>
             </div>` : ''}`;
          return;
        } else {
          pz.attempts++; Sound.lose();
          document.getElementById('puz-prompt').innerHTML =
            `<div style="color:var(--warn); font-weight:700;">${t('puzzle_wrong')}</div>
             ${pz.attempts >= 2 ? `<div class="muted">Подсказка: ход начинается с (${pz.puz.solution.from[0]+1}, ${pz.puz.solution.from[1]+1}).</div>` : ''}`;
          pz.selected = null;
          refreshPuzBoard();
          return;
        }
      }
      if (piece && sgn(piece) === pz.puz.side) {
        pz.selected = [r, c];
        refreshPuzBoard();
      } else {
        pz.selected = null;
        refreshPuzBoard();
      }
    } else if (piece && sgn(piece) === pz.puz.side) {
      pz.selected = [r, c];
      refreshPuzBoard();
    }
  }

