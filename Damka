      else { n1 = tourn.results[0]?.winner; n2 = tourn.results[1]?.winner; if (!n1 || !n2) return; }
      tourn._pendingMatch = { matchIdx, n1, n2 };
      // Start a local 2-player game; on end we record winner
      const g = newGame({
        mode: 'local',
        names: { white: n1, black: n2 },
        avatars: { white: '⚪', black: '⚫' },
