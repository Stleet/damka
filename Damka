  function tickTimers() {
    const g = state.game;
    if (!g || !g.blitz || g.status !== 'playing') return;
    const now = Date.now();
    if (g.timers.lastTick == null) g.timers.lastTick = now;
    const dt = now - g.timers.lastTick;
    g.timers.lastTick = now;
    if (g.sideToMove === WHITE) g.timers.white -= dt;
    else g.timers.black -= dt;
    if (g.timers.white <= 0) { g.timers.white = 0; g.status = 'won-black'; }
    else if (g.timers.black <= 0) { g.timers.black = 0; g.status = 'won-white'; }
    renderGame();
    if (g.status !== 'playing') {
      clearInterval(g.timerHandle); g.timerHandle = null;
      handleGameEnd();
    }
  }

