  function renderTournamentBracket() {
    const tourn = state.tournament;
    const r = tourn.results;
    const winnerOf = (m) => m === null ? null : (m.winner);
    const semiW1 = winnerOf(r[0]);
    const semiW2 = winnerOf(r[1]);
    const champion = winnerOf(r[2]);
    function playerCell(name, winState) {
      const cls = winState === 'win' ? 'win' : winState === 'lose' ? 'lose' : '';
      return `<div class="bracket-player ${cls}">${escapeHTML(name || '?')}</div>`;
    }
    function matchCell(matchIdx, n1, n2) {
      const result = r[matchIdx];
      const playable = !result && n1 && n2;
      const w1 = result && result.winner === n1 ? 'win' : (result ? 'lose' : '');
      const w2 = result && result.winner === n2 ? 'win' : (result ? 'lose' : '');
      return `<div class="bracket-match ${playable?'playable':''}" ${playable?`onclick="App._playMatch(${matchIdx})"`:''}>
        ${playerCell(n1, w1)}
        <div class="bracket-sep"></div>
        ${playerCell(n2, w2)}
      </div>`;
    }
    showModal(`
      <button class="modal-close" onclick="closeModal()">✕</button>
      <h2>🏆 ${t('mode_tournament')}</h2>
      <p class="modal-sub">Кликните на матч, чтобы сыграть его за устройством.</p>
      <div class="bracket">
        <div class="bracket-round">
          <div class="muted" style="font-size:11px; text-transform:uppercase; letter-spacing:0.5px;">Полуфинал</div>
          ${matchCell(0, tourn.names[0], tourn.names[1])}
          ${matchCell(1, tourn.names[2], tourn.names[3])}
        </div>
        <div class="bracket-round">
          <div class="muted" style="font-size:11px; text-transform:uppercase; letter-spacing:0.5px;">Финал</div>
          ${matchCell(2, semiW1, semiW2)}
        </div>
        <div class="bracket-round">
          <div class="muted" style="font-size:11px; text-transform:uppercase; letter-spacing:0.5px;">${t('tourney_winner')}</div>
          <div class="bracket-match" style="background:linear-gradient(135deg,#ffe18c,#d4a242); color:#2a1c00; font-weight:800; min-height:80px;">
            ${champion ? `🏆 ${escapeHTML(champion)}` : '—'}
          </div>
        </div>
      </div>
      <div class="modal-actions">
        ${champion ? `<button class="btn btn-primary grow" onclick="App._resetTournament()">Новый турнир</button>` : ''}
        <button class="btn btn-ghost grow" onclick="closeModal()">Закрыть</button>
      </div>
    `);
  }

  // ============ Cloud leaderboard (Firebase REST) ============
  // Free Firebase project: set firebaseUrl in profile to enable real sync.
  // URL format: https://YOUR-PROJECT.firebaseio.com  (Realtime DB)
  // Rules must allow public read; demo writes to /lb.json
  async function cloudLBPush() {
    const url = state.profile.firebaseUrl;
    if (!url) return false;
    const p = state.profile;
    const entry = {
      nickname: p.nickname || 'Игрок', city: p.city, rating: p.stats.rating,
      avatar: p.avatar, ts: Date.now(),
      id: p._cloudId || (p._cloudId = 'usr_' + Math.random().toString(36).slice(2,10)),
    };
    saveProfile();
    try {
      // Upsert: PUT /lb/<id>.json
      await fetch(`${url.replace(/\/$/,'')}/lb/${entry.id}.json`, {
        method: 'PUT', body: JSON.stringify(entry),
      });
      return true;
    } catch { return false; }
  }
  async function cloudLBFetch() {
    const url = state.profile.firebaseUrl;
    if (!url) return null;
    try {
      const resp = await fetch(`${url.replace(/\/$/,'')}/lb.json`);
      if (!resp.ok) return null;
      const data = await resp.json();
      if (!data) return [];
      return Object.values(data).filter(x => x && x.nickname);
    } catch { return null; }
  }

