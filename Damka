    const me = { id: 'me', name: p.nickname || 'Вы', city: p.city, rating: p.stats.rating, avatar: p.avatar };
    const localMe = localLb.find(e => e.id === 'me') || me;
    // Merge: fake + local me + cloud entries (deduped by city+name+rating-ish)
    const cloudArr = (cloudLBCache || []).map(e => ({
      id: e.id, name: e.nickname || e.name, city: e.city || '—',
      rating: e.rating, avatar: e.avatar || '👤'
