    },

    rematch() {
      closeModal();
      const g = state.game;
      if (!g) { this.go('menu'); return; }
      if (g.campaign) {
        if (g.campaign.isBoss) this.startCampaignBoss(g.campaign.worldId);
        else this.startCampaignLevel(g.campaign.worldId, g.campaign.levelIdx);
        return;
      }
      if (g.mode === 'ai') this.startAI(g.aiLevel);
      else if (g.mode === 'local') this.startLocal();
      else this.go('menu');
    },

    openShareLink(id) {
      if (!id) { showToast('Комната недоступна'); return; }
      const url = location.origin + location.pathname + '?room=' + id;
      showModal(`
        <button class="modal-close" onclick="closeModal()">✕</button>
        <h2>Пригласить друга</h2>
        <p class="modal-sub">Отправьте эту ссылку, чтобы пригласить ещё одного игрока в комнату.</p>
        <div class="share-link-row">
          <input id="share-url" value="${url}" readonly />
          <button class="btn btn-primary btn-sm" onclick="App.copyShareLink()">Копировать</button>
        </div>
      `);
    },

    upgradePro() {
      // Mock Stripe checkout
      showModal(`
        <h2>💳 Stripe Checkout</h2>
        <p class="modal-sub">Демонстрационный режим — реальная оплата не производится.</p>
        <div class="modal-row"><div>Дамка Pro — Месячная подписка</div><div><strong>$4.99</strong></div></div>
        <div class="modal-row"><div>Налог</div><div>$0.00</div></div>
        <div class="modal-row"><div><strong>Итого</strong></div><div><strong>$4.99 / мес</strong></div></div>
        <div class="modal-actions">
          <button class="btn btn-ghost grow" onclick="closeModal()">Отмена</button>
          <button class="btn btn-primary grow" onclick="App.completePro()">Оплатить (демо)</button>
        </div>
      `);
    },
    completePro() {
      state.profile.isPro = true;
      saveProfile();
      closeModal();
      showToast('🎉 Pro активирован! Все скины разблокированы.');
      renderMenu();
    },

    saveProfileForm() {
      const nick = document.getElementById('prof-nick').value.trim() || 'Игрок';
      const city = document.getElementById('prof-city').value;
      const av = document.querySelector('#prof-av-picker .sel')?.dataset.av || state.profile.avatar;
      state.profile.nickname = nick.slice(0, 22);
      state.profile.city = city;
      state.profile.avatar = av;
      saveProfile();
      closeModal();
      renderMenu();
    },

    confirmReset() {
      showModal(`
        <h2>Сбросить статистику?</h2>
        <p class="modal-sub">Это удалит ваш рейтинг и историю побед. Действие необратимо.</p>
        <div class="modal-actions">
          <button class="btn btn-ghost grow" onclick="App.showProfile()">Отмена</button>
          <button class="btn btn-danger grow" onclick="App.doReset()">Сбросить</button>
        </div>
      `);
    },
    doReset() {
      state.profile.stats = { wins: 0, losses: 0, draws: 0, rating: 1000, gamesByMode: {} };
      saveProfile();
      Storage.set('lb', []);
      closeModal();
      renderMenu();
    },
  };
  window.App = App;

  // ===== Helpers =====
  function escapeHTML(s) {
    return String(s ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
  }

  // ===== Init =====
  function init() {
    state.profile = loadProfile();
    applyTheme();
    // If joining via ?room=
    const params = new URLSearchParams(location.search);
    const room = params.get('room');
    if (!state.profile.nickname) {
      renderOnboarding();
      // After onboarding, joining will be handled separately if room param is present
      if (room) {
        // Save it for after onboarding
        state._pendingRoom = room;
      }
      // Wrap finishOnboarding to honor pending room
      const origFinish = App.finishOnboarding;
      App.finishOnboarding = function() {
        origFinish.call(App);
        if (state._pendingRoom) {
          const r = state._pendingRoom; state._pendingRoom = null;
          setTimeout(() => joinMultiplayer(r), 200);
        }
      };
    } else if (room) {
      renderMenu();
      setTimeout(() => joinMultiplayer(room), 200);
    } else {
      renderMenu();
    }
  }

  window.addEventListener('error', (e) => {
    console.error('Global error:', e.error);
  });

  // ===== PWA: Service worker + install prompt =====
  let installPrompt = null;
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    installPrompt = e;
    state._canInstall = true;
    if (state.view === 'menu') renderMenu();
  });
  window.addEventListener('appinstalled', () => {
    installPrompt = null; state._canInstall = false;
    showToast(t('pwa_installed'));
  });
  if ('serviceWorker' in navigator && location.protocol !== 'file:') {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('./sw.js').catch(() => {});
    });
  }
  window.promptInstall = function() {
    if (installPrompt) {
      installPrompt.prompt();
      installPrompt.userChoice.finally(() => { installPrompt = null; state._canInstall = false; });
    } else {
      showToast('Установка недоступна (или приложение уже установлено)');
    }
  };

  init();
  </script>
</body>
</html>
