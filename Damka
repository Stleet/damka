    let targets = new Set(); let captureTargets = new Set();
    if (pz.selected) {
      const moves = legalMoves(pz.board, pz.puz.side);
      const fromMoves = moves.filter(m => m.steps[0][0] === pz.selected[0] && m.steps[0][1] === pz.selected[1]);
      for (const m of fromMoves) {
        const e = m.steps[m.steps.length-1];
        if (m.captures.length) captureTargets.add(e[0]+','+e[1]);
        else targets.add(e[0]+','+e[1]);
      }
    }
    let h = '';
    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) {
      const dark = (r+c)%2===1;
      const k = r+','+c;
      const sel = pz.selected && pz.selected[0]===r && pz.selected[1]===c;
      const tgt = targets.has(k) ? 'target' : '';
      const cap = captureTargets.has(k) ? 'target cap' : '';
      const piece = pz.board[r][c];
      let pieceHTML = '';
      if (piece) {
        const isW = piece > 0;
        const isK = Math.abs(piece) === 2;
        const style = isW
          ? `--piece-w:${sk.w}; --piece-w-edge:${sk.edgeW}`
          : `--piece-b:${sk.b}; --piece-b-edge:${sk.edgeB}`;
        pieceHTML = `<div class="puz-piece ${isW?'w':'b'} ${isK?'king':''}" style="${style}"></div>`;
      }
      h += `<div class="puz-cell ${dark?'dark':'light'} ${sel?'sel':''} ${tgt} ${cap}" onclick="App._puzClick(${r},${c})">${pieceHTML}</div>`;
    }
    return h;
  }
