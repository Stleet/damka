  function joinMultiplayer(roomId) {
    if (window.PEERJS_FAILED || typeof Peer === 'undefined') {
      showToast('Мультиплеер недоступен (PeerJS не загрузился)');
      return;
    }
    showModal(`<h2>🔗 Подключение...</h2><p class="modal-sub">Соединяемся с комнатой ${roomId}</p>`, { dismissable: false });
