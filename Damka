    return SKIN_CATALOG[kind].find(s => s.id === id) || SKIN_CATALOG[kind][0];
  }

  function rollFromBox(boxType) {
    const cfg = BOX_TYPES[boxType];
    const r = Math.random();
    let acc = 0;
    let pickedRarity = Object.keys(cfg.drops)[0];
    for (const [rar, p] of Object.entries(cfg.drops)) {
      acc += p;
      if (r < acc) { pickedRarity = rar; break; }
    }
    // 50/50 piece or board; fallback if pool empty for that rarity
    let kind = Math.random() < 0.5 ? 'pieces' : 'boards';
    let pool = SKIN_CATALOG[kind].filter(s => s.rarity === pickedRarity);
    if (pool.length === 0) {
      kind = kind === 'pieces' ? 'boards' : 'pieces';
      pool = SKIN_CATALOG[kind].filter(s => s.rarity === pickedRarity);
    }
    const skin = pool[Math.floor(Math.random() * pool.length)];
    return { kind, skin, rarity: pickedRarity };
  }

