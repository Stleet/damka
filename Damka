  }

  function onMpData(d) {
    if (!d || typeof d !== 'object') return;
    if (d.type === 'hello') {
      const g = state.game;
      if (g) {
        if (g.playerSide === WHITE) { g.names.black = d.name; g.avatars.black = d.avatar; }
        else { g.names.white = d.name; g.avatars.white = d.avatar; }
        renderGame();
      }
      // Remember opponent info for friends/chat
      if (state.multiplayer) {
        state.multiplayer.opponent = {
          name: d.name, avatar: d.avatar, city: d.city || '',
          peerId: (state.multiplayer.role === 'host') ? (state.multiplayer.conn && state.multiplayer.conn.peer) : state.multiplayer.roomId,
        };
      }
    } else if (d.type === 'chat') {
      pushChat('them', String(d.text || '').slice(0, 200));
      // If chat modal is closed, show a brief toast
      if (!document.getElementById('chat-msgs')) showToast('💬 ' + String(d.text || '').slice(0, 60));
    } else if (d.type === 'move') {
      const g = state.game; if (!g) return;
      const before = cloneBoard(g.board);
      g.board = applyMove(g.board, d.move);
      g.moveHistory.push({ board: before, move: d.move, side: g.sideToMove });
      Sound.move();
      if (d.move.captures.length) Sound.capture();
      g.sideToMove = -g.sideToMove;
      g.status = checkGameStatus(g.board, g.sideToMove);
      renderGame();
      if (g.status !== 'playing') handleGameEnd();
    } else if (d.type === 'resign') {
      const g = state.game; if (!g) return;
      g.status = g.playerSide === WHITE ? 'won-white' : 'won-black';
      renderGame();
      handleGameEnd();
    }
  }
  function onMpClose() {
    showToast('Соперник вышел из игры');
    const g = state.game;
    if (g && g.status === 'playing') {
      g.status = g.playerSide === WHITE ? 'won-white' : 'won-black';
      renderGame();
      handleGameEnd();
    }
  }
