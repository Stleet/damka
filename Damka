  function renderWorld(world, wi, camp) {
    const prevDefeated = wi === 0 ? true : camp.bosses.includes(WORLDS[wi-1].id);
    const unlocked = prevDefeated;
    const progress = camp.progress[world.id] || 0;
    const bossDefeated = camp.bosses.includes(world.id);
    const positions = nodePositions();
    const bp = bossPosition();

    if (!unlocked) {
      return `
        <div class="world-card locked" style="--world-color:${world.color}; --world-color-2:${world.color2};">
          <div class="world-head">
            <div class="emoji">${world.emoji}</div>
            <div class="grow">
              <div class="title">${world.name} 🔒</div>
              <div class="desc">${world.desc}</div>
            </div>
          </div>
          <div class="world-locked-cta">
            Победите босса предыдущего мира, чтобы открыть эту локацию
          </div>
        </div>`;
    }

    const nodes = world.levels.map((l, li) => {
      const locked = li > progress;
      const completed = li < progress;
      const cls = locked ? 'locked' : completed ? 'completed' : 'available';
      const pos = positions[li];
      const onclick = !locked ? `onclick="App.startCampaignLevel('${world.id}', ${li})"` : '';
      const icon = locked ? '🔒' : l.avatar;
      return `
        <div class="map-node ${cls}" style="left:${pos.left}; top:${pos.top};" ${onclick}>
          <div class="circle">${icon}</div>
          <div class="name">${escapeHTML(l.name)}</div>
          <div class="rating">${l.rating}</div>
        </div>`;
    }).join('');

    const bossLocked = progress < world.levels.length;
    const bossCls = bossLocked ? 'locked' : bossDefeated ? 'completed' : 'available';
    const bossClick = !bossLocked ? `onclick="App.startCampaignBoss('${world.id}')"` : '';
    const bossNode = `
      <div class="map-node boss ${bossCls}" style="left:${bp.left}; top:${bp.top};" ${bossClick}>
        <div class="circle">${bossLocked ? '🔒' : world.boss.avatar}</div>
        <div class="name">${escapeHTML(world.boss.name)}</div>
        <div class="rating">${world.boss.rating}</div>
      </div>`;

    return `
      <div class="world-card" style="--world-color:${world.color}; --world-color-2:${world.color2};">
        <div class="world-head">
          <div class="emoji">${world.emoji}</div>
          <div class="grow">
            <div class="title">${world.name}</div>
            <div class="desc">${world.desc}</div>
          </div>
          <div class="progress">${progress}/${world.levels.length}${bossDefeated ? ' ✓' : ''}</div>
        </div>
        <div class="world-map">
          <svg class="map-bg" viewBox="0 0 600 280" preserveAspectRatio="none">
            <path d="M 60 175 Q 130 30 250 175 T 460 175 T 580 130" fill="none" stroke="rgba(255,255,255,0.30)" stroke-width="3" stroke-dasharray="7 7"/>
          </svg>
          ${nodes}
          ${bossNode}
        </div>
      </div>`;
  }

  // ===== Game screen =====
  function renderGame() {
    const g = state.game;
    if (!g) { renderMenu(); return; }
    const me = state.profile;
    const showCoachHint = me.coachHints && !state.aiThinking && g.status === 'playing'
                          && (g.mode === 'ai' && g.sideToMove === g.playerSide || g.mode === 'local' || g.mode === 'blitz' || g.mode === 'online');
    root.innerHTML = `
      ${renderTopbar()}
      <div class="game-layout">
        <div class="game-main">
          ${renderPlayerStrip(g, 'top')}
          <div class="board-wrap"><div class="board" id="board"></div></div>
          ${renderPlayerStrip(g, 'bottom')}
        </div>
        <div class="sidebar">
          ${renderControls(g)}
          ${renderMovesPanel(g)}
          ${showCoachHint ? renderInlineCoach(g) : ''}
        </div>
      </div>
    `;
    renderBoardCells();
  }

  function renderPlayerStrip(g, pos) {
    // For non-online: black is top, white is bottom (player perspective)
    // For online host plays white at bottom; guest plays black at bottom (flipped).
    const flipped = isFlipped(g);
    const topSide  = flipped ? WHITE : BLACK;
    const botSide  = flipped ? BLACK : WHITE;
    const side = pos === 'top' ? topSide : botSide;
    const name = side === WHITE ? g.names.white : g.names.black;
    const av   = side === WHITE ? g.avatars.white : g.avatars.black;
    const captures = countPieces(g.board, -side); // opponents lost = how many we captured = 12 - opp count
    const ours = countPieces(g.board, side);
    const lost = 12 - ours;
    const active = g.sideToMove === side && g.status === 'playing';
    const time = g.blitz ? formatTime(side === WHITE ? g.timers.white : g.timers.black) : null;
    const low = time && (side === WHITE ? g.timers.white : g.timers.black) < 30000;
    return `
      <div class="player-strip ${active ? 'active' : ''}">
        <div class="player-info">
          <div class="player-avatar">${av}</div>
          <div>
            <div class="player-name">${escapeHTML(name)}</div>
            <div class="player-meta">${side === WHITE ? 'Белые' : 'Чёрные'} • Потеряно ${lost}/12</div>
          </div>
        </div>
        ${time !== null ? `<div class="player-clock ${low ? 'low' : ''}">${time}</div>` : ''}
      </div>
    `;
  }

  function isFlipped(g) {
    // Flip board so the human's pieces are at the bottom
    // Default: white at bottom (rows 5-7). If player plays black against AI / online, flip.
    if (g.mode === 'ai' && g.playerSide === BLACK) return true;
    if (g.mode === 'online' && g.playerSide === BLACK) return true;
    return false;
  }

  function renderControls(g) {
    const canUndo = g.moveHistory.length > 0 && g.mode !== 'online' && g.status === 'playing';
    return `
      <div class="panel">
        <h3>Партия</h3>
        <div class="ctrls">
          <button class="btn btn-sm" onclick="App.confirmExit()">⏎ Меню</button>
          <button class="btn btn-sm" onclick="App.requestUndo()" ${canUndo ? '' : 'disabled'}>↶ Отмена</button>
          <button class="btn btn-sm" onclick="App.toggleHints()">${state.profile.coachHints ? '💡 Подсказки' : '🔕 Подсказки'}</button>
          <button class="btn btn-sm" onclick="App.toggleSound()">${state.profile.sound ? '🔊' : '🔇'} Звук</button>
          ${g.mode === 'online' && state.multiplayer ? `<button class="btn btn-sm" onclick="App.openShareLink('${state.multiplayer.roomId || ''}')">🔗 Пригласить</button>` : ''}
          ${g.mode === 'online' ? `<button class="btn btn-sm" onclick="App.openChat()">💬 Чат</button>` : ''}
          ${g.mode === 'online' && state.multiplayer?.opponent ? `<button class="btn btn-sm" onclick="App._addOpponentToFriends()">＋ В друзья</button>` : ''}
        </div>
      </div>
    `;
  }

  function renderMovesPanel(g) {
    const turns = [];
    for (let i = 0; i < g.moveHistory.length; i += 2) {
      const a = g.moveHistory[i];
      const b = g.moveHistory[i+1];
      turns.push({num: i/2 + 1, w: a, b: b});
    }
    const isLast = (idx) => idx === g.moveHistory.length - 1;
    return `
      <div class="panel">
        <h3>Ходы ${g.moveHistory.length ? `(${g.moveHistory.length})` : ''}</h3>
        <div class="moves-list">
          ${turns.length === 0 ? `<div class="muted" style="grid-column:1/-1; font-size:13px;">Партия только начинается…</div>` : ''}
          ${turns.map(t => `
            <div class="turn-num">${t.num}.</div>
            <div class="mv ${t.w && isLast(g.moveHistory.indexOf(t.w)) ? 'cur' : ''}">${t.w ? moveToNotation(t.w.move) : ''}</div>
            <div class="mv ${t.b && isLast(g.moveHistory.indexOf(t.b)) ? 'cur' : ''}">${t.b ? moveToNotation(t.b.move) : ''}</div>
          `).join('')}
        </div>
      </div>
    `;
  }

  function renderInlineCoach(g) {
    const moves = legalMoves(g.board, g.sideToMove);
    if (moves.length === 0) return '';
    const coach = getCoach(g.coachId);
    const anyCap = moves.some(m => m.captures.length > 0);
    let text;
    if (anyCap) {
      const max = moves.reduce((a,m) => Math.max(a, m.captures.length), 0);
      const count = moves.filter(m => m.captures.length).length;
      text = max > 1 ? coach.multiCap(max) : coach.cap(count);
    } else {
      // Pick advisory: center vs back-rank vs idle, by ply
      const ply = g.moveHistory.length;
      const hasCenterMove = moves.some(m => {
        const t = m.steps[m.steps.length - 1];
        return t[0] >= 3 && t[0] <= 4 && t[1] >= 2 && t[1] <= 5;
      });
      if (hasCenterMove && ply < 16) text = coach.center();
      else if (ply < 8)              text = coach.defense();
      else                            text = coach.idle();
    }
    return `
      <div class="coach-bubble" style="--char-color:${coach.color}; --char-glow:${coach.glow};">
        <div class="coach-avatar">${coach.emoji}</div>
        <div class="coach-body">
          <div class="coach-name">
            <span>${escapeHTML(coach.name)}</span>
            <span class="swap" title="Другой тренер" onclick="App.shuffleCoach()">↻ сменить</span>
          </div>
          <div class="coach-text">${escapeHTML(text)}</div>
        </div>
      </div>`;
  }

  function applyBoardSkin() {
    const wrap = document.querySelector('.board-wrap');
    if (!wrap) return;
    const skin = getSkin('boards', state.profile.equipped.board);
    wrap.style.setProperty('--board-light', skin.light);
    wrap.style.setProperty('--board-dark', skin.dark);
    wrap.style.setProperty('--board-light-2', skin.light2 || skin.light);
    wrap.style.setProperty('--board-dark-2', skin.frame);
  }

  function renderBoardCells() {
    const g = state.game;
    const board = document.getElementById('board');
    if (!board) return;
    const flipped = isFlipped(g);
    board.className = 'board';
    board.innerHTML = '';
    applyBoardSkin();
    const pieceSkin = getSkin('pieces', state.profile.equipped.piece);
    const sel = g.selected;
    const possibleTargets = new Set(); // "r,c"
    const captureTargets = new Set();
    for (const m of g.avail) {
      const t = m.steps[m.steps.length - 1];
      const key = t[0] + ',' + t[1];
      if (m.captures.length) captureTargets.add(key);
      else possibleTargets.add(key);
    }
    const mustHL = new Set();
    if (state.profile.coachHints && !sel && g.status === 'playing') {
      // Highlight pieces that MUST move (have available captures)
      const myMoves = legalMoves(g.board, g.sideToMove);
      const anyCap = myMoves.some(m => m.captures.length > 0);
      if (anyCap) {
        for (const m of myMoves) if (m.captures.length) mustHL.add(m.steps[0][0] + ',' + m.steps[0][1]);
      }
    }
    // Last move highlight
    const last = g.moveHistory[g.moveHistory.length - 1];
    const lastSet = new Set();
    if (last) {
      lastSet.add(last.move.steps[0][0] + ',' + last.move.steps[0][1]);
      const t = last.move.steps[last.move.steps.length - 1];
      lastSet.add(t[0] + ',' + t[1]);
    }

    for (let r = 0; r < 8; r++) {
      for (let c = 0; c < 8; c++) {
        const dr = flipped ? 7 - r : r;
        const dc = flipped ? 7 - c : c;
        const piece = g.board[dr][dc];
        const cell = document.createElement('div');
        const isDark = (dr + dc) % 2 === 1;
        cell.className = 'cell ' + (isDark ? 'dark' : 'light');
        cell.dataset.r = dr; cell.dataset.c = dc;
        const key = dr + ',' + dc;
        if (sel && sel[0] === dr && sel[1] === dc) cell.classList.add('cell-hl-selected');
        if (lastSet.has(key)) cell.classList.add('cell-hl-last');
        if (possibleTargets.has(key)) cell.classList.add('cell-hl-possible');
        if (captureTargets.has(key)) cell.classList.add('cell-hl-capture');
        // Coordinate marks on edge cells
        if (c === 0) {
          const mk = document.createElement('div'); mk.className = 'cell-mark';
          mk.textContent = String(8 - dr);
          cell.appendChild(mk);
        }
        if (r === 7) {
          const mk2 = document.createElement('div'); mk2.className = 'cell-mark';
          mk2.style.top = 'auto'; mk2.style.bottom = '2px'; mk2.style.left = 'auto'; mk2.style.right = '4px';
          mk2.textContent = 'abcdefgh'[dc];
          cell.appendChild(mk2);
        }
        if (piece) {
          const p = document.createElement('div');
          p.className = 'piece ' + (piece > 0 ? 'w' : 'b') + (isKing(piece) ? ' king' : '');
          // Apply equipped piece skin via CSS vars
          if (piece > 0) {
            p.style.setProperty('--piece-w', pieceSkin.w);
            p.style.setProperty('--piece-w-edge', pieceSkin.edgeW);
          } else {
            p.style.setProperty('--piece-b', pieceSkin.b);
            p.style.setProperty('--piece-b-edge', pieceSkin.edgeB);
          }
          if (sel && sel[0] === dr && sel[1] === dc) p.classList.add('selected');
          if (mustHL.has(key)) p.classList.add('must');
          const myTurn = canHumanInteract();
          if (myTurn && sgn(piece) === g.sideToMove) p.classList.add('draggable');
          cell.appendChild(p);
        }
        cell.addEventListener('click', () => onCellClick(dr, dc));
        board.appendChild(cell);
      }
    }
  }

  function canHumanInteract() {
    const g = state.game;
    if (!g || g.status !== 'playing' || state.aiThinking) return false;
    if (g.mode === 'ai' && g.sideToMove !== g.playerSide) return false;
    if (g.mode === 'online' && g.sideToMove !== g.playerSide) return false;
    return true;
  }

  function onCellClick(r, c) {
    const g = state.game;
    if (!canHumanInteract()) return;
    const piece = g.board[r][c];

    // Selecting own piece
    if (piece !== 0 && sgn(piece) === g.sideToMove) {
      const all = legalMoves(g.board, g.sideToMove);
      // If captures mandatory, only pieces with captures can be selected
      const anyCap = all.some(m => m.captures.length > 0);
      const myMoves = all.filter(m => m.steps[0][0] === r && m.steps[0][1] === c);
      const valid = anyCap ? myMoves.filter(m => m.captures.length > 0) : myMoves;
      if (valid.length === 0) { showToast('Эта шашка не может ходить'); return; }
      // If we're in middle of multi-jump, only the moving piece can be selected
      if (g.mustContinueFrom && (g.mustContinueFrom[0] !== r || g.mustContinueFrom[1] !== c)) {
        showToast('Нужно продолжить взятие');
        return;
      }
      g.selected = [r, c];
      g.avail = valid;
      Sound.select();
      renderBoardCells();
      return;
    }
    // Clicking target
    if (g.selected) {
      const match = g.avail.find(m => {
        const t = m.steps[m.steps.length - 1];
        return t[0] === r && t[1] === c;
      });
      if (match) {
        executeMove(match);
        return;
      } else {
        // Maybe partial multi-jump step? Find moves where this is an intermediate step.
        const partial = g.avail.find(m => m.steps[1] && m.steps[1][0] === r && m.steps[1][1] === c);
        if (partial && partial.captures.length > 1) {
          // Make first hop only and continue
          executePartialJump(partial);
          return;
        }
      }
    }
  }

  function executePartialJump(fullMove) {
    // Execute just the first jump of a multi-jump
    const g = state.game;
    const partial = {
      steps: [fullMove.steps[0], fullMove.steps[1]],
      captures: [fullMove.captures[0]],
      piece: fullMove.piece,
    };
    const before = cloneBoard(g.board);
    const after = applyMove(g.board, partial);
    g.board = after;
    // Don't push to history yet — we'll combine the whole multi-jump.
    // Instead, we keep an accumulator. Actually simpler: just execute the whole multi-jump.
    // For UX, breaking it apart is nice but introduces bugs. Let's execute the full move instead.
    g.board = applyMove(before, fullMove);
    const m = fullMove;
    finalizeMove(before, m);
  }

  function executeMove(move) {
    const g = state.game;
    const before = cloneBoard(g.board);
    const after = applyMove(g.board, move);
    g.board = after;
    finalizeMove(before, move);
  }

  function finalizeMove(before, move) {
    const g = state.game;
    g.moveHistory.push({ board: before, move, side: g.sideToMove });
    g.selected = null; g.avail = []; g.mustContinueFrom = null;
    // Sound
    if (move.captures.length) Sound.capture(); else Sound.move();
    // Check promotion
    const [tr, tc] = move.steps[move.steps.length - 1];
    const piece = g.board[tr][tc];
    const beforePiece = before[move.steps[0][0]][move.steps[0][1]];
    if (isKing(piece) && !isKing(beforePiece)) Sound.king();
    // Switch turn
    g.sideToMove = -g.sideToMove;
    g.status = checkGameStatus(g.board, g.sideToMove);
    // Online: send move
    if (g.mode === 'online' && state.multiplayer?.conn) {
      try { state.multiplayer.conn.send({ type: 'move', move }); } catch {}
    }
    renderGame();
    if (g.status !== 'playing') {
      handleGameEnd();
      return;
    }
    if (g.mode === 'ai' && g.sideToMove !== g.playerSide) {
      runAITurn();
    }
  }

  function runAITurn() {
    const g = state.game;
    state.aiThinking = true;
    renderGame();
    // Async via setTimeout so UI updates
    setTimeout(() => {
      try {
        const move = pickAIMove(g.board, g.sideToMove, g.aiLevel);
        if (!move) {
          g.status = checkGameStatus(g.board, g.sideToMove);
          state.aiThinking = false;
          renderGame();
          if (g.status !== 'playing') handleGameEnd();
          return;
        }
        const before = cloneBoard(g.board);
        g.board = applyMove(g.board, move);
        g.moveHistory.push({ board: before, move, side: g.sideToMove });
        Sound.move();
        if (move.captures.length) Sound.capture();
        const [tr, tc] = move.steps[move.steps.length - 1];
        const piece = g.board[tr][tc];
        const beforePiece = before[move.steps[0][0]][move.steps[0][1]];
        if (isKing(piece) && !isKing(beforePiece)) Sound.king();
        g.sideToMove = -g.sideToMove;
        g.status = checkGameStatus(g.board, g.sideToMove);
        state.aiThinking = false;
        renderGame();
        if (g.status !== 'playing') handleGameEnd();
      } catch (e) {
        console.error(e);
        state.aiThinking = false;
        renderGame();
      }
    }, 200);
  }

  function handleGameEnd() {
    const g = state.game;
    if (g.timerHandle) { clearInterval(g.timerHandle); g.timerHandle = null; }
    let myResult = 'draw';
    let playerSide = g.mode === 'local' ? null : g.playerSide;
    if (playerSide) {
      if (g.status === 'won-white' && playerSide === WHITE) myResult = 'win';
      else if (g.status === 'won-black' && playerSide === BLACK) myResult = 'win';
      else myResult = 'loss';
    }
    if (playerSide) recordResult(myResult);
    if (myResult === 'win') Sound.win(); else if (myResult === 'loss') Sound.lose();

    // Tournament: record winner of the played match
    if (g._tournamentMatch && state.tournament) {
      const m = g._tournamentMatch;
      const winnerName = g.status === 'won-white' ? m.n1 : m.n2;
      state.tournament.results[m.matchIdx] = { winner: winnerName };
      // After local match, we'll show a small banner and a button to bracket
    }

    // Cloud LB sync (fire-and-forget)
    if (state.profile.firebaseUrl) cloudLBPush().catch(()=>{});

    // Award a box on win
    let awarded = null;
    let campaignNote = '';
    if (myResult === 'win' || (g.mode === 'local' && g.status !== 'playing')) {
      awarded = pickBoxForWin(g);
      // Campaign overrides
      if (g.campaign && myResult === 'win') {
        const { worldId, levelIdx, isBoss } = g.campaign;
        const camp = state.profile.campaign;
        if (isBoss) {
          const firstTime = !camp.bosses.includes(worldId);
          if (firstTime) {
            camp.bosses.push(worldId);
            awarded = 'gold';
            const w = getWorld(worldId);
            const nextIdx = WORLDS.findIndex(x => x.id === worldId) + 1;
            const nextWorld = WORLDS[nextIdx];
            campaignNote = `🏆 ${w.name} пройдена! ` + (nextWorld ? `Открыт мир: ${nextWorld.emoji} ${nextWorld.name}` : 'Вы прошли всю кампанию! Великий мастер!');
          } else {
            awarded = 'silver';
            campaignNote = `Повторная победа над боссом ${getWorld(worldId).boss.name}.`;
          }
        } else {
          const prevProg = camp.progress[worldId] || 0;
          if (levelIdx === prevProg) {
            camp.progress[worldId] = prevProg + 1;
            awarded = 'silver';
            const w = getWorld(worldId);
            const remaining = w.levels.length - camp.progress[worldId];
            campaignNote = remaining > 0
              ? `Уровень пройден! Осталось ${remaining} до босса.`
              : `🔓 Босс ${w.boss.name} открыт!`;
          } else {
            awarded = 'cardboard';
          }
        }
      }
      state.profile.boxes[awarded] = (state.profile.boxes[awarded] || 0) + 1;
      saveProfile();
    }

    const won = g.status === 'won-white' ? 'белые' : g.status === 'won-black' ? 'чёрные' : null;
    let title, emoji, sub;
    if (g.mode === 'local') {
      title = `Победили ${won}!`;
      emoji = '🏆';
      sub = `Партия завершена за ${g.moveHistory.length} полуходов`;
    } else if (myResult === 'win') {
      title = 'Вы победили!';
      emoji = '🏆';
      sub = `Рейтинг +18 • Партия за ${g.moveHistory.length} полуходов`;
    } else if (myResult === 'loss') {
      title = 'Поражение';
      emoji = '😔';
      sub = `Рейтинг −12 • Не сдавайтесь — AI Coach покажет ваши ошибки`;
    } else {
      title = 'Ничья';
      emoji = '🤝';
      sub = `Партия завершена`;
    }
    const rewardHTML = awarded ? `
      <div class="reward-display rarity-${awarded === 'gold' ? 'legendary' : awarded === 'silver' ? 'epic' : 'common'}">
        <div class="reward-icon-wrap">
          <div class="reward-icon">${BOX_TYPES[awarded].icon}</div>
        </div>
        <div class="reward-text">
          <div class="reward-title">+1 ${BOX_TYPES[awarded].name} коробка</div>
          <div class="reward-sub">Откройте её в инвентаре 🎒</div>
        </div>
      </div>` : '';
    const campBannerHTML = campaignNote ? `<div class="camp-banner" style="margin: 10px 0;"><span class="emoji">⚔️</span><div><strong>${escapeHTML(campaignNote)}</strong></div></div>` : '';
    const backLabel = g._tournamentMatch ? '🏆 К турниру' : (g.campaign ? 'К карте мира' : 'В меню');
    const backAction = g._tournamentMatch ? "App.forceExit(); App.openTournament();" : "App._backFromGame()";
    showModal(`
      <div class="result-emoji">${emoji}</div>
      <div class="result-title">${title}</div>
      <div class="result-sub">${sub}</div>
      ${campBannerHTML}
      ${rewardHTML}
      <div class="result-grid">
        <div class="result-stat"><div class="v">${g.moveHistory.length}</div><div class="l">Ходов</div></div>
        <div class="result-stat"><div class="v">${Math.round((Date.now() - g.started)/60000)}м</div><div class="l">Длительность</div></div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-primary" onclick="App.startAnalysis()">📊 Разбор партии</button>
        <button class="btn" onclick="App.rematch()">⟳ Реванш</button>
        <button class="btn btn-ghost" onclick="${backAction}">${backLabel}</button>
      </div>
    `);
  }

